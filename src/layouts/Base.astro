---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** active nav key: home | how | roadmap | constitution | contact */
  active?: string;
}

const {
  title = 'storytree — software, built in the open',
  description = 'storytree is an experiment in building software out in the open — by people and AI agents at once — and staying fair and trustworthy because of that openness, not in spite of it.',
  active = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- social card -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#2f6b3f" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- fonts: Fraunces (display) + Inter (body); degrade to system stacks if offline -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,420;9..144,560;9..144,620&family=Inter:wght@400;500;600;650&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Nav active={active} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
