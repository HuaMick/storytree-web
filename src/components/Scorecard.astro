---
// ---------------------------------------------------------------------------
// Scorecard — the three-surfaces survey as a tools × surfaces matrix.
// Each surface mark is sourced from a primary doc (linked). The point the table
// makes at a glance: every surveyed tool builds one or two surfaces; in this
// survey, none builds all three. Rendered as a semantic <table> (screen-reader
// friendly out of the box) styled as a board, with SVG dot glyphs in the cells.
// Honesty note carried in the caption: the surface labels are our framing.
// Source: docs/research/three-surfaces-landscape/three-surfaces.md (2026-06-08).
// ---------------------------------------------------------------------------

type Mark = 'full' | 'partial' | 'none';

interface Row {
  tool: string;
  href: string;
  note: string;            // what surface it actually builds, in one phrase
  library: Mark;
  map: Mark;
  board: Mark;
  us?: boolean;
}

const rows: Row[] = [
  { tool: 'Aider', href: 'https://aider.chat/docs/repomap.html',
    note: 'tree-sitter repo map', library: 'none', map: 'full', board: 'none' },
  { tool: 'CodeGraph', href: 'https://github.com/colbymchenry/codegraph',
    note: 'a queryable code graph', library: 'none', map: 'full', board: 'none' },
  { tool: 'Augment Code', href: 'https://www.augmentcode.com/blog/a-real-time-index-for-your-codebase-secure-personal-scalable',
    note: 'real-time codebase index', library: 'none', map: 'full', board: 'none' },
  { tool: 'Sourcegraph Cody', href: 'https://sourcegraph.com/blog/how-cody-understands-your-codebase',
    note: 'code retrieval over repos', library: 'none', map: 'full', board: 'none' },
  { tool: 'Anthropic Skills + memory', href: 'https://www.anthropic.com/engineering/equipping-agents-for-the-real-world-with-agent-skills',
    note: 'loadable knowledge tier', library: 'full', map: 'none', board: 'none' },
  { tool: 'Letta / MemGPT', href: 'https://docs.letta.com',
    note: 'structured memory blocks', library: 'full', map: 'none', board: 'none' },
  { tool: 'Beads', href: 'https://github.com/steveyegge/beads/blob/main/README.md',
    note: 'dependency-aware task graph', library: 'none', map: 'none', board: 'full' },
  { tool: 'Gas Town', href: 'https://github.com/steveyegge/gastown',
    note: 'work-first orchestration', library: 'none', map: 'none', board: 'full' },
  { tool: 'loom', href: 'https://github.com/ghuntley/loom',
    note: 'thread search + VCS tooling, unintegrated', library: 'partial', map: 'partial', board: 'none' },
  { tool: 'storytree', href: '/how-it-works/',
    note: 'one model, all three surfaces', library: 'full', map: 'full', board: 'full', us: true },
];

const cols: { key: 'library' | 'map' | 'board'; label: string; sub: string }[] = [
  { key: 'library', label: 'Library', sub: 'what’s known' },
  { key: 'map', label: 'Code map', sub: 'what the system is' },
  { key: 'board', label: 'Work-board', sub: 'what’s being done' },
];

const markText: Record<Mark, string> = { full: 'yes', partial: 'partial', none: 'no' };
---

<figure class="sc">
  <table class="sc__table">
    <caption class="sc__caption">
      Tools surveyed × the three surfaces. <span aria-hidden="true">●</span> a primary source
      supports a direct analog; <span aria-hidden="true">◐</span> a weak or unintegrated parallel.
    </caption>
    <thead>
      <tr>
        <th scope="col" class="sc__th-tool">Tool</th>
        {cols.map((c) => (
          <th scope="col" class="sc__th-surface">
            <span class="sc__th-label">{c.label}</span>
            <span class="sc__th-sub">{c.sub}</span>
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((r) => (
        <tr class={r.us ? 'sc__row sc__row--us' : 'sc__row'}>
          <th scope="row" class="sc__tool">
            <a href={r.href}>{r.tool}</a>
            <span class="sc__note">{r.note}</span>
          </th>
          {cols.map((c) => (
            <td class="sc__cell" data-mark={r[c.key]}>
              <span class="sc__dot" data-mark={r[c.key]} aria-hidden="true">
                {r[c.key] === 'full' && (
                  <svg viewBox="0 0 18 18" width="16" height="16"><circle cx="9" cy="9" r="6.5" /></svg>
                )}
                {r[c.key] === 'partial' && (
                  <svg viewBox="0 0 18 18" width="16" height="16">
                    <circle cx="9" cy="9" r="6.5" class="sc__dot-ring" />
                    <path d="M9 2.5 A6.5 6.5 0 0 0 9 15.5 Z" class="sc__dot-half" />
                  </svg>
                )}
                {r[c.key] === 'none' && (
                  <svg viewBox="0 0 18 18" width="16" height="16"><line x1="6" y1="9" x2="12" y2="9" /></svg>
                )}
              </span>
              <span class="sc__sr">{markText[r[c.key]]}</span>
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>

  <p class="sc__callout">
    <strong>One or two surfaces each.</strong> In this survey, none had all three.
  </p>

  <figcaption class="sc__legend">
    <span class="sc__leg"><span class="sc__chip sc__chip--full" aria-hidden="true"></span>direct analog</span>
    <span class="sc__leg"><span class="sc__chip sc__chip--partial" aria-hidden="true"></span>partial / unintegrated</span>
    <span class="sc__leg"><span class="sc__chip sc__chip--none" aria-hidden="true"></span>not found</span>
    <span class="sc__source">
      Scored from primary sources, Jun 2026. The surface labels are our framing, not the tools’ own — see
      <a href="/landscape/#caveats">the caveats</a>.
    </span>
  </figcaption>
</figure>

<style>
  .sc {
    margin: 1.6rem 0 0;
    background: linear-gradient(180deg, #fbf3ea, #f4e6d6);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .sc__table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
  .sc__caption {
    caption-side: top; text-align: left; color: var(--ink-soft);
    font-size: 0.86rem; padding: 0.95rem 1.1rem 0.2rem;
  }
  .sc__caption span { color: var(--evergreen); font-weight: 700; }

  thead th { vertical-align: bottom; padding: 0.7rem 0.5rem 0.8rem; }
  .sc__th-tool {
    text-align: left; padding-left: 1.1rem; color: var(--ink-faint);
    font-family: var(--font-body); font-size: 0.72rem; font-weight: 650;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .sc__th-surface { text-align: center; width: 22%; }
  .sc__th-label { display: block; font-family: var(--font-display); font-size: 1.02rem; font-weight: 600; color: var(--ink); }
  .sc__th-sub { display: block; font-size: 0.72rem; color: var(--ink-faint); font-style: italic; margin-top: 0.1rem; }

  .sc__row { border-top: 1px solid var(--line); }
  .sc__tool {
    text-align: left; padding: 0.7rem 0.5rem 0.7rem 1.1rem; font-weight: 500;
  }
  .sc__tool a { color: var(--ink); text-decoration: none; font-weight: 600; border-bottom: 1px solid var(--line-strong); }
  .sc__tool a:hover { color: var(--evergreen-deep); border-color: var(--evergreen); }
  .sc__note { display: block; font-size: 0.78rem; color: var(--ink-faint); font-weight: 400; margin-top: 0.05rem; }

  .sc__cell { text-align: center; padding: 0.7rem 0.5rem; }
  .sc__dot { display: inline-flex; }
  .sc__dot svg circle { fill: var(--evergreen); }
  .sc__dot[data-mark='partial'] svg .sc__dot-ring { fill: none; stroke: var(--sage); stroke-width: 1.6; }
  .sc__dot[data-mark='partial'] svg .sc__dot-half { fill: var(--sage); }
  .sc__dot[data-mark='none'] svg line { stroke: var(--line-strong); stroke-width: 2; stroke-linecap: round; }

  /* storytree's row — the only full triad */
  .sc__row--us { background: var(--evergreen-soft); }
  .sc__row--us .sc__tool a { color: var(--evergreen-deep); border-color: var(--evergreen); }
  .sc__row--us .sc__dot svg circle { fill: var(--evergreen-deep); }

  .sc__sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }

  .sc__callout {
    margin: 0; padding: 0.95rem 1.1rem;
    background: var(--evergreen); color: #fdf6ec;
    font-size: 1.02rem; text-align: center;
  }
  .sc__callout strong { color: #fff; }

  .sc__legend {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 1.3rem;
    padding: 0.85rem 1.1rem; background: var(--surface);
    border-top: 1px solid var(--line); font-size: 0.83rem; color: var(--ink-soft);
  }
  .sc__leg { display: inline-flex; align-items: center; }
  .sc__chip { width: 0.78rem; height: 0.78rem; border-radius: 999px; margin-right: 0.45em; display: inline-block; }
  .sc__chip--full { background: var(--evergreen); }
  .sc__chip--partial { background: linear-gradient(90deg, var(--sage) 0 50%, transparent 50% 100%); border: 1.5px solid var(--sage); }
  .sc__chip--none { background: transparent; border: 2px solid var(--line-strong); }
  .sc__source { flex-basis: 100%; color: var(--ink-faint); font-size: 0.8rem; }

  @media (max-width: 560px) {
    .sc__table { font-size: 0.9rem; }
    .sc__th-tool, .sc__tool { padding-left: 0.7rem; }
    .sc__th-surface { width: 20%; }
    .sc__th-sub { display: none; }
    .sc__cell { padding: 0.6rem 0.3rem; }
  }
</style>
