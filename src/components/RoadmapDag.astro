---
import data from '../data/roadmap.json';

// ---------------------------------------------------------------------------
// RoadmapDag — storytree's roadmap rendered as a dependency map, not a timeline.
// Arrows read "this came first, and it unlocks that". Milestone nodes are gates:
// real-world conditions that must be true before the work behind them unlocks.
// All-SVG (scales as one unit on small screens); an accessible text breakdown
// is rendered beneath it for screen readers and narrow viewports.
// ---------------------------------------------------------------------------

type Status = 'done' | 'building' | 'next' | 'gated' | 'gate';

const TONE: Record<Status, { fill: string; stroke: string; dot: string; label: string }> = {
  done:     { fill: '#e7f1e6', stroke: '#2f6b3f', dot: '#2f6b3f', label: 'Built' },
  building: { fill: '#e4eef0', stroke: '#2f6f7d', dot: '#2f6f7d', label: 'Building now' },
  next:     { fill: '#fdeede', stroke: '#9a5a1c', dot: '#9a5a1c', label: 'Next up' },
  gated:    { fill: '#f1ece2', stroke: '#9b8a6f', dot: '#9b8a6f', label: 'Waiting on a gate' },
  gate:     { fill: '#fbefd6', stroke: '#b07d1c', dot: '#b07d1c', label: 'Milestone' },
};

const W = 192;
const MW = 220;
const LINE_H = 19;
const COND_H = 16;

function wrap(text: string, max: number, maxLines: number): string[] {
  const words = text.split(' ');
  const lines: string[] = [];
  let cur = '';
  for (const w of words) {
    if ((cur + ' ' + w).trim().length > max && cur) { lines.push(cur); cur = w; }
    else cur = (cur + ' ' + w).trim();
  }
  if (cur) lines.push(cur);
  if (lines.length > maxLines) {
    const kept = lines.slice(0, maxLines);
    kept[maxLines - 1] = (kept[maxLines - 1] ?? '').replace(/[.,;:]?$/, '') + '…';
    return kept;
  }
  return lines;
}

type Node = (typeof data.nodes)[number];
type Geom = {
  lines: string[]; condLines: string[]; w: number; h: number; cx: number; cy: number;
  eyebrowY: number; titleYs: number[]; condYs: number[]; statusY: number;
};

// Stack each node's text top-to-bottom, returning baselines relative to the box top.
const geom = new Map<string, Geom>();
for (const n of data.nodes) {
  const isM = n.kind === 'milestone';
  const lines = wrap(n.title, isM ? 26 : 22, 3);
  const condLines = isM ? wrap((n as Node & { condition?: string }).condition ?? '', 32, 2) : [];
  const w = isM ? MW : W;

  let y = 14;                       // top padding
  let eyebrowY = 0;
  if (isM) { y += 4; eyebrowY = y + 8; y += 20; }
  y += 6;
  const titleYs: number[] = [];
  for (let i = 0; i < lines.length; i++) { titleYs.push(y + 13); y += LINE_H; }
  const condYs: number[] = [];
  if (isM) { y += 6; for (let i = 0; i < condLines.length; i++) { condYs.push(y + 12); y += COND_H; } }
  y += 20;                          // gap before the status row
  const statusY = y + 4;
  y += 16 + 14;                     // status row + bottom padding
  const h = y;

  geom.set(n.id, { lines, condLines, w, h, cx: n.x, cy: n.y, eyebrowY, titleYs, condYs, statusY });
}

const pos: Record<string, { x: number; y: number }> = {};
for (const n of data.nodes) pos[n.id] = { x: n.x, y: n.y };
const statusOf: Record<string, Status> = {};
for (const n of data.nodes) statusOf[n.id] = n.status as Status;

// edges: from dependency (lower on the board) up into the node it unlocks
const edges = data.nodes.flatMap((n) =>
  (n.dependsOn ?? []).map((depId) => {
    const dg = geom.get(depId)!;
    const ng = geom.get(n.id)!;
    const ax = dg.cx, ay = dg.cy - dg.h / 2;        // top of dependency
    const bx = ng.cx, by = ng.cy + ng.h / 2;        // bottom of dependent
    const my = (ay + by) / 2;
    const settled = statusOf[depId] === 'done' && (n.status === 'done' || n.status === 'building');
    return { d: `M ${ax} ${ay} C ${ax} ${my}, ${bx} ${my}, ${bx} ${by}`, settled };
  })
);

const nodes = data.nodes.map((n) => {
  const g = geom.get(n.id)!;
  const tone = TONE[n.status as Status];
  const isM = n.kind === 'milestone';
  return {
    ...n,
    g,
    tone,
    isM,
    x0: g.cx - g.w / 2,
    y0: g.cy - g.h / 2,
  };
});

// ---- accessible breakdown groups (the canonical reading content) ----
const byId = Object.fromEntries(data.nodes.map((n) => [n.id, n]));
const built = data.nodes.filter((n) => n.status === 'done');
const buildingNow = data.nodes.filter((n) => n.status === 'building' || n.status === 'next');
const milestones = data.nodes.filter((n) => n.kind === 'milestone');
function unlockedBy(id: string) {
  return data.nodes.filter((n) => n.kind === 'work' && (n.dependsOn ?? []).includes(id));
}

const legend: { cls: Status; label: string }[] = [
  { cls: 'done', label: 'Built' },
  { cls: 'building', label: 'Building now' },
  { cls: 'next', label: 'Next up' },
  { cls: 'gate', label: 'Milestone (a gate)' },
  { cls: 'gated', label: 'Waiting on a gate' },
];
---

<figure class="rmap" id="roadmap-dag">
  <div class="rmap__stage">
    <svg
      viewBox={data.viewBox}
      role="img"
      aria-label="storytree's roadmap as a dependency map. Built foundations sit at the bottom; arrows point upward to the work each one unlocks. Two milestone gates — a real circle of members, and being able to sustain itself — must be reached before the work above them is built."
    >
      <defs>
        <radialGradient id="rm-board" cx="50%" cy="62%" r="80%">
          <stop offset="0" stop-color="#fbf3ea" />
          <stop offset="1" stop-color="#f1e2d2" />
        </radialGradient>
        <filter id="rm-soft" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="3" stdDeviation="5" flood-color="#5a3f1f" flood-opacity="0.12" />
        </filter>
        <marker id="rm-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M 0 1 L 9 5 L 0 9 z" fill="#9c8259" />
        </marker>
        <marker id="rm-arrow-on" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M 0 1 L 9 5 L 0 9 z" fill="#5b8a5f" />
        </marker>
      </defs>

      <rect x="0" y="0" width="960" height="780" fill="url(#rm-board)" />

      <!-- edges: an arrow means "this unlocks that" -->
      <g class="rm-edges">
        {edges.map((e) => (
          <path
            d={e.d}
            fill="none"
            stroke={e.settled ? '#5b8a5f' : '#b29a72'}
            stroke-width={e.settled ? 2.6 : 2.2}
            stroke-linecap="round"
            stroke-dasharray={e.settled ? undefined : '2 8'}
            marker-end={e.settled ? 'url(#rm-arrow-on)' : 'url(#rm-arrow)'}
            opacity={e.settled ? 0.9 : 0.8}
          />
        ))}
      </g>

      <!-- nodes -->
      {nodes.map((n) => (
        <g class={`rm-node ${n.isM ? 'rm-node--gate' : ''}`} id={`rm-${n.id}`}>
          {n.isM ? (
            <polygon
              points={`${n.g.cx},${n.y0} ${n.x0 + n.g.w},${n.y0 + 16} ${n.x0 + n.g.w},${n.y0 + n.g.h} ${n.x0},${n.y0 + n.g.h} ${n.x0},${n.y0 + 16}`}
              fill={n.tone.fill}
              stroke={n.tone.stroke}
              stroke-width="2"
              filter="url(#rm-soft)"
            />
          ) : (
            <rect
              x={n.x0}
              y={n.y0}
              width={n.g.w}
              height={n.g.h}
              rx="14"
              fill={n.tone.fill}
              stroke={n.tone.stroke}
              stroke-width={n.status === 'gated' ? 1.6 : 2}
              stroke-dasharray={n.status === 'gated' ? '5 4' : undefined}
              filter="url(#rm-soft)"
            />
          )}

          {/* milestone eyebrow */}
          {n.isM && (
            <text x={n.g.cx} y={n.y0 + n.g.eyebrowY} text-anchor="middle" class="rm-eyebrow" fill={n.tone.stroke}>◆ MILESTONE · A GATE</text>
          )}

          {/* title */}
          {n.g.lines.map((ln, li) => (
            <text x={n.g.cx} y={n.y0 + n.g.titleYs[li]!} text-anchor="middle" class="rm-title" fill="#221f1a">{ln}</text>
          ))}

          {/* milestone condition */}
          {n.isM && n.g.condLines.map((ln, li) => (
            <text x={n.g.cx} y={n.y0 + n.g.condYs[li]!} text-anchor="middle" class="rm-cond" fill="#5d564c">{ln}</text>
          ))}

          {/* status row */}
          <g transform={`translate(${n.g.cx}, ${n.y0 + n.g.statusY})`}>
            <circle cx={-n.tone.label.length * 3.0 - 7} cy="-3.5" r="4" fill={n.tone.dot} />
            <text x="2" y="0" text-anchor="middle" class="rm-status" fill={n.tone.stroke}>
              {n.status === 'gated' ? '🔒 ' : ''}{n.tone.label}
            </text>
          </g>
        </g>
      ))}

      <!-- hit targets on top so hover/focus always works -->
      <g class="rm-hits">
        {nodes.map((n) => (
          <rect
            class="rm-hit"
            x={n.x0}
            y={n.y0}
            width={n.g.w}
            height={n.g.h}
            rx="14"
            fill="transparent"
            tabindex="0"
            role="button"
            data-id={n.id}
            data-title={n.title}
            data-short={n.short}
            data-status={n.status}
            data-label={n.isM ? `Milestone — ${(n as any).condition}` : n.tone.label}
            aria-label={`${n.title}. ${n.tone.label}. ${n.short}`}
          />
        ))}
      </g>
    </svg>

    <!-- tooltip -->
    <div class="rm-tip" hidden role="status" aria-live="polite">
      <div class="rm-tip__head">
        <span class="rm-tip__dot"></span>
        <span class="rm-tip__title"></span>
      </div>
      <p class="rm-tip__short"></p>
      <p class="rm-tip__label"></p>
    </div>
  </div>

  <figcaption class="rmap__legend">
    {legend.map((l) => (
      <span class="rmap__leg"><span class={`rmap__chip rmap__chip--${l.cls}`}></span>{l.label}</span>
    ))}
    <span class="rmap__hint">Read bottom-up · an arrow means “unlocks”</span>
  </figcaption>
</figure>

<!-- accessible / mobile breakdown of the same map -->
<div class="rmap-text">
  <div class="rmap-text__group">
    <h3><span class="dot dot--healthy"></span>Built — the foundation</h3>
    <p class="muted">The trunk everything else grows from. These exist today.</p>
    <ul>
      {built.map((n) => (<li><strong>{n.title}.</strong> {n.short}</li>))}
    </ul>
  </div>

  <div class="rmap-text__group">
    <h3><span class="rmap__chip rmap__chip--building"></span>Building now &amp; next</h3>
    <p class="muted">Unlocked by the foundation, and where the work is pointed right now.</p>
    <ul>
      {buildingNow.map((n) => (
        <li><strong>{n.title}.</strong> {n.short} <em class="rmap-text__tag">{TONE[n.status as Status].label}</em></li>
      ))}
    </ul>
  </div>

  {milestones.map((m) => (
    <div class="rmap-text__group rmap-text__group--gate">
      <h3><span class="rmap__chip rmap__chip--gate"></span>Gate · {m.title}</h3>
      <p class="muted">{(m as any).condition} {m.short}</p>
      <p class="rmap-text__unlocks">Unlocks once this is true:</p>
      <ul>
        {unlockedBy(m.id).map((n) => (
          <li><strong>{n.title}.</strong> {n.short}</li>
        ))}
      </ul>
    </div>
  ))}
</div>

<style>
  .rmap {
    margin: 1.5rem 0 0;
    background: linear-gradient(180deg, #fbf3ea, #f4e6d6);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .rmap__stage { position: relative; }
  .rmap__stage svg { width: 100%; height: auto; display: block; }

  .rm-eyebrow { font-family: var(--font-body); font-size: 9px; font-weight: 700; letter-spacing: 0.12em; }
  .rm-title { font-family: var(--font-display); font-size: 14.5px; font-weight: 600; }
  .rm-cond { font-family: var(--font-body); font-size: 11px; font-style: italic; }
  .rm-status { font-family: var(--font-body); font-size: 10.5px; font-weight: 650; letter-spacing: 0.02em; }

  .rm-node { transition: transform 0.18s ease; transform-box: fill-box; transform-origin: center; }
  .rm-node.is-active { transform: translateY(-3px) scale(1.02); }
  .rm-hit { cursor: pointer; outline: none; }
  .rm-hit:focus-visible { outline: 2.5px solid var(--amber); outline-offset: -3px; border-radius: 14px; }

  /* tooltip */
  .rm-tip {
    position: absolute; z-index: 5; left: 0; top: 0;
    transform: translate(-50%, calc(-100% - 14px));
    width: min(20rem, 76vw);
    background: var(--surface);
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    box-shadow: var(--shadow);
    padding: 0.8rem 0.95rem;
    pointer-events: none;
  }
  .rm-tip[hidden] { display: none; }
  .rm-tip::after {
    content: ""; position: absolute; left: 50%; bottom: -7px; transform: translateX(-50%) rotate(45deg);
    width: 12px; height: 12px; background: var(--surface);
    border-right: 1px solid var(--line-strong); border-bottom: 1px solid var(--line-strong);
  }
  .rm-tip__head { display: flex; align-items: center; gap: 0.5rem; }
  .rm-tip__dot { width: 0.7rem; height: 0.7rem; border-radius: 999px; background: var(--amber); flex: none; }
  .rm-tip__title { font-family: var(--font-display); font-weight: 600; font-size: 1.05rem; }
  .rm-tip__short { margin: 0.45rem 0 0.45rem; font-size: 0.92rem; color: var(--ink-soft); line-height: 1.45; }
  .rm-tip__label { margin: 0; font-size: 0.78rem; color: var(--ink-faint); font-weight: 600; }

  /* legend */
  .rmap__legend {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 1.2rem;
    padding: 0.85rem 1.1rem; border-top: 1px solid var(--line);
    background: var(--surface); font-size: 0.85rem; color: var(--ink-soft);
  }
  .rmap__leg { display: inline-flex; align-items: center; }
  .rmap__chip {
    display: inline-block; width: 0.72rem; height: 0.72rem; border-radius: 4px;
    margin-right: 0.45em; border: 2px solid var(--evergreen); background: var(--evergreen-soft);
  }
  .rmap__chip--done { border-color: #2f6b3f; background: #e7f1e6; }
  .rmap__chip--building { border-color: #2f6f7d; background: #e4eef0; }
  .rmap__chip--next { border-color: #9a5a1c; background: #fdeede; }
  .rmap__chip--gated { border-color: #9b8a6f; background: #f1ece2; border-style: dashed; }
  .rmap__chip--gate { border-color: #b07d1c; background: #fbefd6; border-radius: 2px; transform: rotate(45deg); }
  .rmap__hint { margin-left: auto; color: var(--ink-faint); font-style: italic; }
  @media (max-width: 620px) { .rmap__hint { margin-left: 0; } }

  /* text breakdown */
  .rmap-text { margin-top: 1.8rem; display: grid; gap: 1.1rem; }
  .rmap-text__group {
    background: var(--surface); border: 1px solid var(--line);
    border-left: 4px solid var(--evergreen);
    border-radius: var(--radius); padding: 1.2rem 1.4rem;
  }
  .rmap-text__group--gate { border-left-color: var(--amber); background: #fffaf1; }
  .rmap-text__group h3 { display: flex; align-items: center; margin-bottom: 0.3rem; font-size: 1.18rem; }
  .rmap-text__group h3 .dot, .rmap-text__group h3 .rmap__chip { margin-right: 0.5rem; }
  .rmap-text__group > p.muted { margin: 0 0 0.7rem; font-size: 0.95rem; }
  .rmap-text__group ul { margin: 0; padding-left: 1.1rem; display: grid; gap: 0.5rem; }
  .rmap-text__group li { color: var(--ink-soft); }
  .rmap-text__group li strong { color: var(--ink); }
  .rmap-text__unlocks { font-weight: 650; color: var(--ink); margin: 0 0 0.5rem; font-size: 0.92rem; }
  .rmap-text__tag {
    display: inline-block; margin-left: 0.3rem; font-style: normal;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase;
    color: var(--amber);
  }
</style>

<script>
  const root = document.getElementById('roadmap-dag');
  if (root) {
    const tip = root.querySelector('.rm-tip') as HTMLElement | null;
    const stage = root.querySelector('.rmap__stage') as HTMLElement | null;
    const hits = Array.from(root.querySelectorAll<SVGRectElement>('.rm-hit'));

    const dotColor: Record<string, string> = {
      done: '#2f6b3f', building: '#2f6f7d', next: '#9a5a1c', gated: '#9b8a6f', gate: '#b07d1c',
    };

    const show = (el: SVGRectElement) => {
      if (!tip || !stage) return;
      const r = el.getBoundingClientRect();
      const cr = stage.getBoundingClientRect();
      (tip.querySelector('.rm-tip__title') as HTMLElement).textContent = el.dataset.title ?? '';
      (tip.querySelector('.rm-tip__short') as HTMLElement).textContent = el.dataset.short ?? '';
      (tip.querySelector('.rm-tip__label') as HTMLElement).textContent = el.dataset.label ?? '';
      (tip.querySelector('.rm-tip__dot') as HTMLElement).style.background = dotColor[el.dataset.status ?? 'next'] ?? '#9a5a1c';

      let left = r.left - cr.left + r.width / 2;
      const half = Math.min(320, cr.width * 0.76) / 2;
      left = Math.max(half + 8, Math.min(cr.width - half - 8, left));
      tip.style.left = left + 'px';
      tip.style.top = r.top - cr.top + 8 + 'px';
      tip.hidden = false;

      root.querySelectorAll('.rm-node.is-active').forEach((n) => n.classList.remove('is-active'));
      document.getElementById('rm-' + el.dataset.id)?.classList.add('is-active');
    };

    const hide = () => {
      if (tip) tip.hidden = true;
      root.querySelectorAll('.rm-node.is-active').forEach((n) => n.classList.remove('is-active'));
    };

    hits.forEach((el) => {
      el.addEventListener('mouseenter', () => show(el));
      el.addEventListener('mouseleave', hide);
      el.addEventListener('focus', () => show(el));
      el.addEventListener('blur', hide);
      el.addEventListener('click', (e) => { e.stopPropagation(); show(el); });
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); show(el); }
        if (e.key === 'Escape') hide();
      });
    });
    document.addEventListener('click', (e) => {
      if (!(e.target as Element)?.closest('.rm-hit')) hide();
    });
  }
</script>
