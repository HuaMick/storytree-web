---
// The nav is just the brand mark now: the info pages it used to link (how-it-works,
// get-involved, contact, constitution) were retired 2026-07-07 — the experience is
// the whole site. This nav shows only on the a11y fallback + 404. `active` is
// accepted for Base.astro compatibility but unused.
interface Props { active?: string; }
---

<header class="nav">
  <div class="wrap nav__inner">
    <a class="brand" href="/" aria-label="storytree home">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 28 28" width="26" height="26" aria-hidden="true">
          <!-- a tiny sprout: trunk + two crowns -->
          <path d="M14 26 V15" stroke="#6e533d" stroke-width="2.1" stroke-linecap="round" fill="none"/>
          <circle cx="14" cy="9.5" r="6.5" fill="#2f6b3f"/>
          <circle cx="9" cy="14" r="4.4" fill="#55a06a"/>
          <circle cx="19" cy="14" r="4.4" fill="#6f9a52"/>
        </svg>
      </span>
      <span class="brand__word">storytree</span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: saturate(1.4) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner { display: flex; align-items: center; min-height: 62px; }
  .brand { display: inline-flex; align-items: center; gap: 0.55rem; text-decoration: none; color: var(--ink); }
  .brand__word { font-family: var(--font-display); font-weight: 600; font-size: 1.28rem; letter-spacing: -0.015em; }
  .brand__mark { display: inline-flex; }
</style>
