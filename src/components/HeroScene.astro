---
// A self-contained, hand-authored landscape that evokes storytree's living
// "world" — hills, a road of dependencies, trees at different growth stages
// (amber sapling → young → proven evergreen) and a signpost. Pure SVG, original
// art; nothing copied from the private studio. Decorative (aria-hidden).
---
<div class="scene" aria-hidden="true">
  <svg viewBox="0 0 760 420" preserveAspectRatio="xMidYMid meet">
    <defs>
      <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#fbf3e6"/>
        <stop offset="1" stop-color="#f6ead8"/>
      </linearGradient>
      <linearGradient id="hillA" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#b6d188"/>
        <stop offset="1" stop-color="#9cc06f"/>
      </linearGradient>
      <linearGradient id="hillB" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#a9c87f"/>
        <stop offset="1" stop-color="#8eb163"/>
      </linearGradient>
      <linearGradient id="hillC" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#c3d99a"/>
        <stop offset="1" stop-color="#aecb80"/>
      </linearGradient>
    </defs>

    <rect width="760" height="420" fill="url(#sky)"/>

    <!-- distant hills -->
    <path d="M0 250 Q170 188 360 232 T760 214 V420 H0 Z" fill="url(#hillC)" opacity="0.85"/>
    <path d="M0 296 Q210 244 430 286 T760 270 V420 H0 Z" fill="url(#hillB)"/>
    <path d="M0 344 Q250 300 470 338 T760 326 V420 H0 Z" fill="url(#hillA)"/>

    <!-- a winding road of dependencies -->
    <path d="M120 416 C200 360 150 322 250 300 C360 276 330 232 430 224 C540 215 560 192 650 196"
          fill="none" stroke="#cdb285" stroke-width="13" stroke-linecap="round" opacity="0.55"/>
    <path d="M120 416 C200 360 150 322 250 300 C360 276 330 232 430 224 C540 215 560 192 650 196"
          fill="none" stroke="#a98e5f" stroke-width="3" stroke-linecap="round" stroke-dasharray="2 12" opacity="0.7"/>

    <!-- wheat tufts -->
    <g stroke="#d6b271" stroke-width="2.4" stroke-linecap="round" opacity="0.85">
      <path d="M196 350 l0 -14 M201 350 l3 -12 M191 350 l-3 -12"/>
      <path d="M520 300 l0 -13 M525 300 l3 -11 M515 300 l-3 -11"/>
    </g>

    <!-- proven evergreen (big, healthy) -->
    <g class="sway sway--slow">
      <rect x="246" y="250" width="9" height="44" rx="4" fill="#6e533d"/>
      <circle cx="250" cy="232" r="34" fill="#2f6b3f"/>
      <circle cx="226" cy="252" r="22" fill="#3d7a4d"/>
      <circle cx="274" cy="252" r="22" fill="#55a06a"/>
      <circle cx="250" cy="216" r="13" fill="#6f9a52"/>
    </g>

    <!-- a young tree (proposed / amber) -->
    <g class="sway">
      <rect x="437" y="214" width="7" height="34" rx="3.5" fill="#7d5f44"/>
      <circle cx="440.5" cy="206" r="22" fill="#b06a24"/>
      <circle cx="427" cy="218" r="13" fill="#c98a3e"/>
      <circle cx="454" cy="218" r="13" fill="#e09a4b"/>
    </g>

    <!-- a sapling just claimed -->
    <g class="sway sway--fast">
      <rect x="635" y="178" width="5" height="24" rx="2.5" fill="#7d5f44"/>
      <circle cx="637.5" cy="172" r="11" fill="#9fc174"/>
      <circle cx="631" cy="178" r="7" fill="#b2cf8b"/>
    </g>

    <!-- a couple of garden flora (capabilities) near the big tree -->
    <g class="bob">
      <path d="M300 300 v-16" stroke="#5d8a46" stroke-width="2.4" stroke-linecap="round"/>
      <circle cx="300" cy="282" r="6" fill="#e6a23c"/>
      <circle cx="300" cy="282" r="2.4" fill="#f7ecd2"/>
    </g>
    <g class="bob bob--2">
      <path d="M196 306 v-15" stroke="#5d8a46" stroke-width="2.4" stroke-linecap="round"/>
      <circle cx="196" cy="289" r="5.5" fill="#cf5b46"/>
      <circle cx="196" cy="289" r="2.2" fill="#f7ecd2"/>
    </g>

    <!-- signpost: a story's human-witness seal -->
    <g class="sway sway--fast">
      <rect x="349" y="244" width="4.5" height="30" rx="2" fill="#8a6f4c"/>
      <circle cx="351" cy="240" r="9" fill="#fffdfa" stroke="#2f6b3f" stroke-width="2.6"/>
      <path d="M347 240 l3 3 l5 -6" fill="none" stroke="#2f6b3f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </g>
  </svg>
</div>

<style>
  .scene { width: 100%; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line); box-shadow: var(--shadow); background: #fbf3e6; }
  .scene svg { width: 100%; height: auto; display: block; }
  .sway { transform-box: fill-box; transform-origin: bottom center; animation: sway 6.5s ease-in-out infinite; }
  .sway--slow { animation-duration: 9s; }
  .sway--fast { animation-duration: 5s; }
  .bob { transform-box: fill-box; transform-origin: bottom center; animation: bob 4.5s ease-in-out infinite; }
  .bob--2 { animation-delay: 1.4s; }
  @keyframes sway { 0%,100% { transform: rotate(-1.1deg); } 50% { transform: rotate(1.1deg); } }
  @keyframes bob { 0%,100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-2px) scale(1.03); } }
  @media (prefers-reduced-motion: reduce) { .sway, .bob { animation: none; } }
</style>
