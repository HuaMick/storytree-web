---
// ---------------------------------------------------------------------------
// AgentMaze — TWO side-by-side mazes telling one A/B story. Same maze layout in
// both panels; the only difference is the map.
//   LEFT  (no map):  the agent thrashes — it walks into a dead end, backs out,
//                    tries another, backs out, and keeps RETURNING to the same
//                    dead ends, getting more desperate, and ends stranded.
//   RIGHT (the map): the agent reads a top-down route and heads straight to the
//                    goal, a torch-cone of vision sweeping ahead in its heading.
// Everything — the maze, the BFS solution route, the thrash route (shortest
// paths shuttled between detected dead ends), the per-segment headings, and the
// CSS travel/rotation keyframes — is computed deterministically at BUILD TIME
// (seeded → identical every visit, ships as static HTML). Motion is pure CSS
// keyframes, so the site's global prefers-reduced-motion rule freezes it on a
// coherent final frame: every animation's 100% keyframe IS the resting state
// (map-agent arrived at the goal; no-map-agent stranded; final bubble showing).
// Original art — nothing copied from the studio.
// ---------------------------------------------------------------------------

const COLS = 7, ROWS = 5, CELL = 46, PAD = 18, TOP = 34;
const W = PAD * 2 + COLS * CELL;
const H = TOP + PAD + ROWS * CELL;

const idx = (c: number, r: number) => r * COLS + c;
const cx = (c: number) => PAD + c * CELL + CELL / 2;
const cy = (r: number) => TOP + r * CELL + CELL / 2;
const inGrid = (c: number, r: number) => c >= 0 && c < COLS && r >= 0 && r < ROWS;

// deterministic RNG (FNV-1a seed → mulberry32) so the maze is stable every build
function hash(s: string): number {
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) { h ^= s.charCodeAt(i); h = Math.imul(h, 16777619); }
  return h >>> 0;
}
function mulberry32(a: number): () => number {
  return function () {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(hash('storytree-maze-ab-201'));

// ---- carve a perfect maze (recursive backtracker) ----
type Walls = { n: boolean; e: boolean; s: boolean; w: boolean };
const walls: Walls[] = Array.from({ length: COLS * ROWS }, () => ({ n: true, e: true, s: true, w: true }));
const seen0 = new Array(COLS * ROWS).fill(false);
const startC = 0, startR = ROWS - 1;
const goalC = COLS - 1, goalR = 0;

(function carve() {
  const stack: [number, number][] = [[startC, startR]];
  seen0[idx(startC, startR)] = true;
  while (stack.length) {
    const [c, r] = stack[stack.length - 1]!;
    const opts: [number, number, keyof Walls][] = [];
    if (inGrid(c, r - 1) && !seen0[idx(c, r - 1)]) opts.push([c, r - 1, 'n']);
    if (inGrid(c + 1, r) && !seen0[idx(c + 1, r)]) opts.push([c + 1, r, 'e']);
    if (inGrid(c, r + 1) && !seen0[idx(c, r + 1)]) opts.push([c, r + 1, 's']);
    if (inGrid(c - 1, r) && !seen0[idx(c - 1, r)]) opts.push([c - 1, r, 'w']);
    if (!opts.length) { stack.pop(); continue; }
    const [nc, nr, dir] = opts[Math.floor(rand() * opts.length)]!;
    const a = walls[idx(c, r)]!, b = walls[idx(nc, nr)]!;
    if (dir === 'n') { a.n = false; b.s = false; }
    else if (dir === 'e') { a.e = false; b.w = false; }
    else if (dir === 's') { a.s = false; b.n = false; }
    else { a.w = false; b.e = false; }
    seen0[idx(nc, nr)] = true;
    stack.push([nc, nr]);
  }
})();

const open = (c: number, r: number, dir: keyof Walls) => !walls[idx(c, r)]![dir];
function neighbours(c: number, r: number): [number, number][] {
  const out: [number, number][] = [];
  if (open(c, r, 'n')) out.push([c, r - 1]);
  if (open(c, r, 'e')) out.push([c + 1, r]);
  if (open(c, r, 's')) out.push([c, r + 1]);
  if (open(c, r, 'w')) out.push([c - 1, r]);
  return out;
}

// shortest path between two cells through open passages (BFS; maze is a tree)
function bfsPath(from: [number, number], to: [number, number]): [number, number][] {
  const prev = new Map<number, number>();
  const q: [number, number][] = [from];
  const seen = new Set<number>([idx(from[0], from[1])]);
  while (q.length) {
    const [c, r] = q.shift()!;
    if (c === to[0] && r === to[1]) break;
    for (const [nc, nr] of neighbours(c, r)) {
      if (!seen.has(idx(nc, nr))) { seen.add(idx(nc, nr)); prev.set(idx(nc, nr), idx(c, r)); q.push([nc, nr]); }
    }
  }
  const path: [number, number][] = [];
  let cur = idx(to[0], to[1]);
  while (true) {
    path.unshift([cur % COLS, Math.floor(cur / COLS)]);
    if (cur === idx(from[0], from[1])) break;
    const p = prev.get(cur);
    if (p === undefined) break;
    cur = p;
  }
  return path;
}

// ---- the map-agent's route: shortest path start → goal ----
const solCells = bfsPath([startC, startR], [goalC, goalR]);

// ---- the no-map-agent's route: thrash. Detect dead ends, then shuttle the
// agent between the same few of them — into A, back out, into B, back to A,
// off to C, back to B… — so it visibly RETURNS to dead ends it already hit. ----
function deadEnds(): [number, number][] {
  const out: [number, number][] = [];
  for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) {
    if (c === startC && r === startR) continue;
    if (c === goalC && r === goalR) continue;
    const ns = neighbours(c, r);
    if (ns.some(([nc, nr]) => nc === goalC && nr === goalR)) continue; // not the goal's doorway
    if (ns.length === 1) out.push([c, r]); // a real dead end in the full maze
  }
  return out;
}
const sameCell = (a: [number, number], b: [number, number]) => a[0] === b[0] && a[1] === b[1];
// the no-map agent shuttles between two central dead ends, returning to each
// several times — into A, back to the junction, into B, back, into A again — so
// it reads as "stuck going in circles". The pair is chosen so no leg ever
// crosses the goal: it must never look like it stumbled onto the code.
function thrashCells(): [number, number][] {
  const des = deadEnds();
  const sc: [number, number] = [startC, startR];
  const gl: [number, number] = [goalC, goalR];
  const hasGoal = (t: [number, number][]) => t.some((p) => p[0] === goalC && p[1] === goalR);
  const distGoal = (c: [number, number]) => bfsPath(gl, c).length;

  const build = (a: [number, number], b: [number, number]) => {
    const tour: [number, number][] = [];
    const push = (s: [number, number][]) => {
      for (let i = 0; i < s.length; i++) {
        if (i === 0 && tour.length && sameCell(tour[tour.length - 1]!, s[0]!)) continue;
        tour.push(s[i]!);
      }
    };
    push(bfsPath(sc, a)); // start → A (the search)
    push(bfsPath(a, b));  // A → junction → B
    push(bfsPath(b, a));  // B → junction → A   (RETURN to A — the same dead end)
    push(bfsPath(a, b));  // A → junction → B   (RETURN to B)
    push(bfsPath(b, a));  // B → junction → A   (RETURN to A again — stranded, panicking)
    return tour.slice(0, 34);
  };

  // dead ends whose search-in path never crosses the goal
  const reach = des.filter((d) => !hasGoal(bfsPath(sc, d)));
  // best pair: a clearly visible shuttle (a corridor of a few cells between
  // them) kept as far from the goal as possible, goal-free end to end
  let best: { a: [number, number]; b: [number, number]; score: number } | null = null;
  for (let i = 0; i < reach.length; i++) for (let j = i + 1; j < reach.length; j++) {
    const a = reach[i]!, b = reach[j]!;
    const ab = bfsPath(a, b);
    if (hasGoal(ab) || ab.length < 4 || ab.length > 14) continue;
    const score = Math.min(distGoal(a), distGoal(b)) * 2 + ab.length;
    if (!best || score > best.score) best = { a, b, score };
  }
  if (best) {
    const tour = build(best.a, best.b);
    if (!hasGoal(tour)) return tour;
  }

  // fallback: deepest goal-free dead end, paced out-and-back twice
  const deep = reach.map((d) => ({ d, p: bfsPath(sc, d) })).sort((x, y) => y.p.length - x.p.length)[0];
  if (!deep || deep.p.length < 2) return [sc];
  const tour: [number, number][] = [];
  [deep.p, [...deep.p].reverse(), deep.p, [...deep.p].reverse()].forEach((s, k) => {
    for (let i = k === 0 ? 0 : 1; i < s.length; i++) tour.push(s[i]!);
  });
  return tour.slice(0, 34);
}
const thrashCells_ = thrashCells();

const toPts = (cells: [number, number][]) => cells.map(([c, r]) => ({ x: +cx(c).toFixed(1), y: +cy(r).toFixed(1) }));
const solPts = toPts(solCells);
const thrashPts = toPts(thrashCells_);
const solD = solPts.map((p, i) => `${i ? 'L' : 'M'} ${p.x} ${p.y}`).join(' ');

// ---- CSS travel keyframes from a route (translate the agent group through the
// cell-centre waypoints). endPct < 100 leaves the agent resting on its last
// frame for the remainder of the loop (map-agent dwells on the goal). ----
function travelKf(name: string, pts: { x: number; y: number }[], endPct: number, jitterEnd: boolean): string {
  const n = pts.length;
  const last = pts[n - 1]!;
  const rows = pts.map((p, i) =>
    `  ${((i / Math.max(n - 1, 1)) * endPct).toFixed(2)}% { transform: translate(${p.x}px, ${p.y}px); }`);
  if (jitterEnd) {
    // frantic shudder, stuck in place at the final dead end
    const j: [number, number][] = [[-3.5, 2.5], [3, -2], [-2, -3], [3.5, 2], [-2.5, 1]];
    const span = 100 - endPct;
    j.forEach(([dx, dy], i) => {
      const pct = endPct + (span * (i + 1)) / (j.length + 1);
      rows.push(`  ${pct.toFixed(2)}% { transform: translate(${(last.x + dx).toFixed(1)}px, ${(last.y + dy).toFixed(1)}px); }`);
    });
  }
  rows.push(`  100% { transform: translate(${last.x}px, ${last.y}px); }`);
  return `@keyframes ${name} {\n${rows.join('\n')}\n}`;
}

// ---- CSS heading keyframes: rotate the map-agent's "head" group (cone + map
// glyph) to face its direction of travel. Grid segments are axis-aligned, so
// per-segment headings are clean N/E/S/W; angles are accumulated (unwrapped) so
// turns take the short way round and never spin 270°. The head holds the old
// heading into a corner, then snaps to the new one just after it. ----
function headingDeg(a: { x: number; y: number }, b: { x: number; y: number }) {
  return Math.atan2(b.y - a.y, b.x - a.x) * 180 / Math.PI; // E=0 S=90 W=180 N=-90
}
function headKf(name: string, pts: { x: number; y: number }[], endPct: number, turn: number): string {
  const segs: number[] = [];
  for (let i = 0; i < pts.length - 1; i++) segs.push(headingDeg(pts[i]!, pts[i + 1]!));
  if (!segs.length) return `@keyframes ${name} { from,to { transform: rotate(0deg); } }`;
  const cum = [segs[0]!];
  for (let i = 1; i < segs.length; i++) {
    const d = ((segs[i]! - cum[i - 1]! + 540) % 360) - 180; // shortest turn, (-180,180]
    cum.push(cum[i - 1]! + d);
  }
  const n = pts.length;
  const T = (i: number) => (i / (n - 1)) * endPct;
  const rows: string[] = [`  0% { transform: rotate(${cum[0]!.toFixed(1)}deg); }`];
  for (let j = 1; j < segs.length; j++) {
    rows.push(`  ${T(j).toFixed(2)}% { transform: rotate(${cum[j - 1]!.toFixed(1)}deg); }`);
    rows.push(`  ${(T(j) + turn).toFixed(2)}% { transform: rotate(${cum[j]!.toFixed(1)}deg); }`);
  }
  const lastA = cum[segs.length - 1]!.toFixed(1);
  rows.push(`  ${endPct.toFixed(2)}% { transform: rotate(${lastA}deg); }`);
  rows.push(`  100% { transform: rotate(${lastA}deg); }`);
  return `@keyframes ${name} {\n${rows.join('\n')}\n}`;
}

const MAP_END = 72, NOMAP_END = 88;
const kf = [
  travelKf('am-travel-map', solPts, MAP_END, false),
  headKf('am-head-map', solPts, MAP_END, 1.4),
  travelKf('am-travel-nomap', thrashPts, NOMAP_END, true),
].join('\n');

// ---- wall segments (deduped); open the entrance (left of start) + exit (right of goal) ----
const segSet = new Set<string>();
for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) {
  const wl = walls[idx(c, r)]!;
  const x0 = PAD + c * CELL, y0 = TOP + r * CELL;
  const add = (x1: number, y1: number, x2: number, y2: number) => segSet.add([x1, y1, x2, y2].join(','));
  if (wl.n) add(x0, y0, x0 + CELL, y0);
  if (wl.w) add(x0, y0, x0, y0 + CELL);
  if (wl.e) add(x0 + CELL, y0, x0 + CELL, y0 + CELL);
  if (wl.s) add(x0, y0 + CELL, x0 + CELL, y0 + CELL);
}
segSet.delete([PAD + startC * CELL, TOP + startR * CELL, PAD + startC * CELL, TOP + startR * CELL + CELL].join(','));
segSet.delete([PAD + goalC * CELL + CELL, TOP + goalR * CELL, PAD + goalC * CELL + CELL, TOP + goalR * CELL + CELL].join(','));
const wallSegs = [...segSet].map((s) => s.split(',').map(Number) as [number, number, number, number]);

const startX = cx(startC), startY = cy(startR);
const goalX = cx(goalC), goalY = cy(goalR);

// vision cone (map agent only) — a torch wedge pointing +x (east) at heading 0
const CONE_LEN = 50, CONE_APEX = 11, CONE_HALF = 30; // degrees
const coneTop = { x: +(CONE_APEX + CONE_LEN * Math.cos(CONE_HALF * Math.PI / 180)).toFixed(1), y: +(-CONE_LEN * Math.sin(CONE_HALF * Math.PI / 180)).toFixed(1) };
const coneD = `M ${CONE_APEX} 0 L ${coneTop.x} ${coneTop.y} A ${CONE_LEN} ${CONE_LEN} 0 0 1 ${coneTop.x} ${-coneTop.y} Z`;

const mapBubbles = [
  { cls: 'am-mb1', t: "I've got the map", w: 122 },
  { cls: 'am-mb2', t: 'this way — proven', w: 130 },
  { cls: 'am-mb3', t: 'found it ✓', w: 96 },
];
const nomapBubbles = [
  { cls: 'am-nb1', t: "where's the file…", w: 138, danger: false },
  { cls: 'am-nb2', t: 'dead end.', w: 84, danger: false },
  { cls: 'am-nb3', t: 'wait — seen this', w: 132, danger: false },
  { cls: 'am-nb4', t: 'just delete the test?!', w: 168, danger: true },
];
---

<figure class="am-pair">
  <!-- ============================ NO MAP ============================ -->
  <div class="am-panel">
    <p class="am-label am-label-bad"><span class="am-swatch am-sw-bad"></span>without the map</p>
    <svg class="am-svg" viewBox={`0 0 ${W} ${H}`} role="img"
         aria-label="An AI agent with no map wandering a maze: it walks into dead ends, backtracks, and keeps returning to the same dead ends, getting stuck and never reaching the goal.">
      <defs>
        <filter id="am-sh-n" x="-40%" y="-40%" width="180%" height="180%">
          <feDropShadow dx="0" dy="1.4" stdDeviation="1.6" flood-color="#3a2a12" flood-opacity="0.16" />
        </filter>
      </defs>

      <rect class="am-card" x="0.5" y="0.5" width={W - 1} height={H - 1} rx="13" />
      <g class="am-walls">
        {wallSegs.map(([x1, y1, x2, y2]) => <line x1={x1} y1={y1} x2={x2} y2={y2} />)}
      </g>

      <text class="am-tag" x={startX} y={H - 9}>start</text>
      <g class="am-goal am-goal-dim" transform={`translate(${goalX} ${goalY})`}>
        <circle class="am-goal-ring" r="15" />
        <circle class="am-goal-dot" r="5.5" />
      </g>

      <g class="am-agent am-agent-nomap" transform={`translate(${startX} ${startY})`}>
        <circle class="am-glow am-glow-nomap" r="15" />
        <circle class="am-dot am-dot-nomap" r="12" />
        <text class="am-fret" x="0" y="0.5">?</text>
        {nomapBubbles.map((b) => (
          <g class={`am-bubble ${b.cls}`}>
            <rect class="am-bub" x={-b.w / 2} y="-50" width={b.w} height="30" rx="9" filter="url(#am-sh-n)" />
            <path class="am-bub-tail" d="M -7 -21 L 7 -21 L 0 -8 Z" />
            <text class={`am-bub-tx ${b.danger ? 'am-danger' : ''}`} x="0" y="-35">{b.t}</text>
          </g>
        ))}
      </g>
    </svg>
    <p class="am-sub">burns its budget grepping in circles — and never gets there.</p>
  </div>

  <!-- ============================ THE MAP ============================ -->
  <div class="am-panel">
    <p class="am-label am-label-good"><span class="am-swatch am-sw-good"></span>with the map</p>
    <svg class="am-svg" viewBox={`0 0 ${W} ${H}`} role="img"
         aria-label="An AI agent carrying storytree's map reading a top-down route straight to the goal, a cone of vision sweeping ahead in its direction of travel.">
      <defs>
        <filter id="am-sh-m" x="-40%" y="-40%" width="180%" height="180%">
          <feDropShadow dx="0" dy="1.4" stdDeviation="1.6" flood-color="#3a2a12" flood-opacity="0.16" />
        </filter>
        <linearGradient id="am-cone-grad" gradientUnits="userSpaceOnUse" x1={CONE_APEX} y1="0" x2={CONE_APEX + CONE_LEN} y2="0">
          <stop offset="0" stop-color="var(--evergreen)" stop-opacity="0.34" />
          <stop offset="1" stop-color="var(--evergreen)" stop-opacity="0" />
        </linearGradient>
      </defs>

      <rect class="am-card" x="0.5" y="0.5" width={W - 1} height={H - 1} rx="13" />
      <g class="am-walls">
        {wallSegs.map(([x1, y1, x2, y2]) => <line x1={x1} y1={y1} x2={x2} y2={y2} />)}
      </g>

      <!-- the route the map hands it -->
      <path class="am-trail" d={solD} />

      <text class="am-tag" x={startX} y={H - 9}>start</text>
      <g class="am-goal" transform={`translate(${goalX} ${goalY})`}>
        <circle class="am-goal-ring" r="15" />
        <circle class="am-goal-dot" r="5.5" />
        <text class="am-tag am-goal-tag" x="0" y="-22">the code it needs</text>
      </g>

      <g class="am-agent am-agent-map" transform={`translate(${startX} ${startY})`}>
        <!-- cone sits BEHIND the dot; both head groups share the heading rotation
             (am-head-map), so cone and map turn together to face the direction of travel -->
        <g class="am-head am-head-map">
          <circle class="am-bound" r="54" fill="none" />
          <path class="am-cone" d={coneD} />
        </g>
        <circle class="am-dot am-dot-map" r="12" />
        <!-- the map the agent holds up — ON TOP of the body so it reads, long axis = heading -->
        <g class="am-head am-head-map">
          <circle class="am-bound" r="54" fill="none" />
          <g class="am-map">
            <rect class="am-map-card" x="-10" y="-6.5" width="20" height="13" rx="2" />
            <path class="am-map-fold" d="M -3.3 -6.5 V 6.5 M 3.3 -6.5 V 6.5" />
            <path class="am-map-route" d="M -6.5 3.6 Q -1.5 -1.6 1.8 0.6 T 6.6 -3.4" />
            <circle class="am-map-here" cx="-6.5" cy="3.6" r="1.4" />
            <circle class="am-map-goal" cx="6.6" cy="-3.4" r="1.9" />
          </g>
        </g>
        {mapBubbles.map((b) => (
          <g class={`am-bubble ${b.cls}`}>
            <rect class="am-bub" x={-b.w / 2} y="-50" width={b.w} height="30" rx="9" filter="url(#am-sh-m)" />
            <path class="am-bub-tail" d="M -7 -21 L 7 -21 L 0 -8 Z" />
            <text class="am-bub-tx" x="0" y="-35">{b.t}</text>
          </g>
        ))}
      </g>
    </svg>
    <p class="am-sub">reads what exists and what's proven — and spends its budget on the task.</p>
  </div>
</figure>

<style is:global set:html={kf}></style>

<style is:global>
  .am-pair {
    margin: 1.6rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem 1.4rem;
  }
  @media (min-width: 640px) { .am-pair { grid-template-columns: 1fr 1fr; } }

  .am-panel { display: flex; flex-direction: column; min-width: 0; }
  .am-svg { width: 100%; height: auto; display: block; overflow: visible; }

  .am-label {
    display: inline-flex; align-items: center; gap: 0.45rem;
    margin: 0 0 0.45rem; font-family: var(--font-body); font-weight: 650;
    font-size: 0.82rem; letter-spacing: 0.04em; text-transform: uppercase;
  }
  .am-label-good { color: var(--evergreen-deep); }
  .am-label-bad { color: var(--crimson); }
  .am-swatch { width: 0.62rem; height: 0.62rem; border-radius: 999px; flex: none; }
  .am-sw-good { background: var(--evergreen); }
  .am-sw-bad { background: var(--crimson); }
  .am-sub { margin: 0.5rem 0 0; font-size: 0.88rem; line-height: 1.45; color: var(--ink-soft); }

  .am-card { fill: #fdf6ec; stroke: var(--line); stroke-width: 1; }
  .am-walls line { stroke: #b58a57; stroke-width: 3.4; stroke-linecap: round; opacity: 0.82; }

  .am-trail { fill: none; stroke: var(--evergreen); stroke-width: 3; stroke-linecap: round; stroke-dasharray: 0.5 8; opacity: 0.4; }

  .am-tag { font: 600 11px var(--font-body); fill: var(--ink-faint); text-anchor: middle; }
  .am-goal-tag { fill: var(--evergreen-deep); }
  .am-goal-ring { fill: none; stroke: var(--evergreen); stroke-width: 2; transform-box: fill-box; transform-origin: center; animation: am-goal-pulse 2.6s ease-in-out infinite; }
  .am-goal-dot { fill: var(--evergreen); }
  .am-goal-dim .am-goal-ring { stroke: var(--ink-faint); opacity: 0.5; animation: none; }
  .am-goal-dim .am-goal-dot { fill: var(--ink-faint); opacity: 0.5; }

  .am-glow { opacity: 0.16; }
  .am-glow-nomap { fill: var(--amber); }
