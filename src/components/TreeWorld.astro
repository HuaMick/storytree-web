---
import data from '../data/mockTree.json';

// ---------------------------------------------------------------------------
// TreeWorld — a self-contained, original rendering of storytree's "story world"
// map, driven entirely by curated mock JSON (a fictional garden-planner app).
// Hand-authored SVG; the palette is borrowed in spirit from the studio's
// Dorfromantik world, but no private source is copied. Pixels only.
// ---------------------------------------------------------------------------

type Status = 'healthy' | 'mapped' | 'proposed' | 'unhealthy';

const COLORS: Record<Status, { lo: string; mid: string; hi: string; top: string }> = {
  healthy:   { lo: '#2f6b3f', mid: '#3d7a4d', hi: '#55a06a', top: '#6f9a52' },
  mapped:    { lo: '#7d5f3b', mid: '#8d6b42', hi: '#a8854f', top: '#bb9a63' },
  proposed:  { lo: '#b06a24', mid: '#c98a3e', hi: '#e09a4b', top: '#ecb56b' },
  unhealthy: { lo: '#9f2d22', mid: '#b8402f', hi: '#c75545', top: '#d98575' },
};
const GRASS = ['#a9c87f', '#9fc174', '#b2cf8b'];

const SQUASH = 0.72;
const DEPTH = 13;

function hexTop(cx: number, cy: number, r: number) {
  const h = r * SQUASH;
  return `${cx - r},${cy} ${cx - r * 0.5},${cy - h} ${cx + r * 0.5},${cy - h} ${cx + r},${cy} ${cx + r * 0.5},${cy + h} ${cx - r * 0.5},${cy + h}`;
}
function hexSide(cx: number, cy: number, r: number, depth: number) {
  const h = r * SQUASH;
  return `${cx + r},${cy} ${cx + r * 0.5},${cy + h} ${cx - r * 0.5},${cy + h} ${cx - r * 0.5},${cy + h + depth} ${cx + r * 0.5},${cy + h + depth} ${cx + r},${cy + depth}`;
}

const pos: Record<string, { x: number; y: number }> = {};
for (const s of data.stories) pos[s.id] = { x: s.x, y: s.y };

const edges = data.stories.flatMap((s) =>
  (s.dependsOn ?? []).map((p) => {
    const a = pos[p]!;
    const b = { x: s.x, y: s.y };
    const my = (a.y + b.y) / 2;
    return { d: `M ${a.x} ${a.y} C ${a.x} ${my}, ${b.x} ${my}, ${b.x} ${b.y}` };
  })
);

const nodes = data.stories
  .map((s, i) => {
    const st = s.status as Status;
    const c = COLORS[st] ?? COLORS.proposed;
    const r = 56 * (s.scale ?? 1);
    const grass = GRASS[i % GRASS.length];
    const floraXs = [-34, 34, -8];
    const flora = s.capabilities.slice(0, 3).map((_, k) => ({ fx: s.x + floraXs[k % 3]!, fy: s.y + (k === 2 ? 24 : 14) }));
    return {
      ...s,
      st,
      c,
      r,
      grass,
      flora,
      isSeal: s.status === 'healthy' && s.witness === 'human',
      capCount: s.capabilities.length,
      capList: s.capabilities.map((cap) => `${cap.title} · ${cap.status}`).join('\n'),
    };
  })
  .sort((a, b) => a.y - b.y);

const legend = [
  { label: 'Proven', cls: 'healthy' },
  { label: 'Brought in', cls: 'mapped' },
  { label: 'Proposed', cls: 'proposed' },
];
---

<figure class="tw" id="treeworld">
  <div class="tw__stage">
    <svg viewBox={data.viewBox} role="img" aria-label="A map of a fictional garden-planner project as a world of trees, where each tree is a story and its colour shows whether it is proven, brought in, or just proposed.">
      <defs>
        <radialGradient id="tw-board" cx="50%" cy="42%" r="75%">
          <stop offset="0" stop-color="#fbf3ea" />
          <stop offset="1" stop-color="#f1e0d2" />
        </radialGradient>
        <filter id="tw-soft" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="6" stdDeviation="7" flood-color="#5a3f1f" flood-opacity="0.10" />
        </filter>
      </defs>

      <rect x="0" y="0" width="960" height="600" fill="url(#tw-board)" />

      <!-- roads: dependency edges -->
      <g class="tw-roads">
        {edges.map((e) => (
          <>
            <path d={e.d} fill="none" stroke="#cdb285" stroke-width="11" stroke-linecap="round" opacity="0.5" />
            <path d={e.d} fill="none" stroke="#a98e5f" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="1 11" opacity="0.7" />
          </>
        ))}
      </g>

      <!-- nodes, back-to-front -->
      {nodes.map((n) => (
        <g class="tw-node" id={`node-${n.id}`}>
          <polygon points={hexSide(n.x, n.y, n.r, DEPTH)} fill="#87985f" />
          <polygon points={hexTop(n.x, n.y, n.r)} fill={n.grass} stroke="#86a05f" stroke-width="1" filter="url(#tw-soft)" />

          {/* flora = capabilities */}
          {n.flora.map((f) => (
            <g class="tw-flora">
              <path d={`M ${f.fx} ${f.fy} v -11`} stroke="#5d8a46" stroke-width="2.1" stroke-linecap="round" />
              <circle cx={f.fx} cy={f.fy - 12} r="4.6" fill={n.c.hi} />
              <circle cx={f.fx} cy={f.fy - 12} r="1.9" fill="#f7ecd2" />
            </g>
          ))}

          {/* the story tree */}
          <g class="tw-crown" style={`transform: translate(${n.x}px, ${n.y}px) scale(${n.scale ?? 1}); animation-delay: ${(n.y % 7) * 0.4}s;`}>
            <rect x="-4.5" y="-42" width="9" height="48" rx="4" fill="#6e533d" />
            <circle cx="0" cy="-56" r="25" fill={n.c.lo} />
            <circle cx="-17" cy="-43" r="16" fill={n.c.mid} />
            <circle cx="17" cy="-43" r="16" fill={n.c.hi} />
            <circle cx="2" cy="-70" r="11" fill={n.c.top} />
          </g>

          {/* human-witness seal on proven stories */}
          {n.isSeal && (
            <g class="tw-seal" transform={`translate(${n.x + n.r * 0.5}, ${n.y - 4})`}>
              <rect x="-1.6" y="-22" width="3.4" height="26" rx="1.6" fill="#8a6f4c" />
              <circle cx="0" cy="-28" r="8.5" fill="#fffdfa" stroke="#2f6b3f" stroke-width="2.4" />
              <path d="M -3.6 -28 l 2.6 2.6 l 4.6 -5.4" fill="none" stroke="#2f6b3f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </g>
          )}
        </g>
      ))}

      <!-- transparent hit targets on a top layer so hover always works -->
      <g class="tw-hits">
        {nodes.map((n) => (
          <rect
            class="tw-hit"
            x={n.x - n.r}
            y={n.y - 98 * (n.scale ?? 1)}
            width={n.r * 2}
            height={98 * (n.scale ?? 1) + n.r * SQUASH + DEPTH}
            rx="18"
            fill="transparent"
            tabindex="0"
            role="button"
            data-id={n.id}
            data-title={n.title}
            data-outcome={n.outcome}
            data-status={n.st}
            data-caps={`${n.capCount} ${n.capCount === 1 ? 'capability' : 'capabilities'}`}
            aria-label={`${n.title}: ${n.outcome} — ${n.st}, ${n.capCount} capabilities`}
          />
        ))}
      </g>
    </svg>

    <!-- tooltip -->
    <div class="tw-tip" hidden role="status" aria-live="polite">
      <div class="tw-tip__head">
        <span class="tw-tip__dot"></span>
        <span class="tw-tip__title"></span>
      </div>
      <p class="tw-tip__outcome"></p>
      <p class="tw-tip__meta"><span class="tw-tip__status"></span> · <span class="tw-tip__caps"></span></p>
    </div>
  </div>

  <figcaption class="tw__legend">
    {legend.map((l) => (
      <span class="tw__leg"><span class={`dot dot--${l.cls}`}></span>{l.label}</span>
    ))}
    <span class="tw__leg tw__leg--seal"><span class="tw__sealmark" aria-hidden="true">✓</span>Signed off by a person</span>
    <span class="tw__hint">Hover or tap a tree</span>
  </figcaption>
</figure>

<style>
  .tw {
    margin: 1.5rem 0 0;
    background: linear-gradient(180deg, #fbf3ea, #f5e8d9);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .tw__stage { position: relative; }
  .tw__stage svg { width: 100%; height: auto; display: block; }

  .tw-node { transition: transform 0.2s ease; transform-box: fill-box; transform-origin: center bottom; }
  .tw-node.is-active { transform: translateY(-6px) scale(1.035); }

  .tw-crown { transform-box: fill-box; transform-origin: bottom center; animation: tw-sway 6.5s ease-in-out infinite; }
  @keyframes tw-sway { 0%, 100% { rotate: -1deg; } 50% { rotate: 1deg; } }

  .tw-hit { cursor: pointer; outline: none; }
  .tw-hit:focus-visible { outline: 2.5px solid var(--amber); outline-offset: -4px; border-radius: 18px; }

  /* tooltip */
  .tw-tip {
    position: absolute; z-index: 5; left: 0; top: 0;
    transform: translate(-50%, calc(-100% - 14px));
    width: min(19rem, 74vw);
    background: var(--surface);
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    box-shadow: var(--shadow);
    padding: 0.8rem 0.95rem;
    pointer-events: none;
  }
  .tw-tip[hidden] { display: none; }
  .tw-tip::after {
    content: ""; position: absolute; left: 50%; bottom: -7px; transform: translateX(-50%) rotate(45deg);
    width: 12px; height: 12px; background: var(--surface);
    border-right: 1px solid var(--line-strong); border-bottom: 1px solid var(--line-strong);
  }
  .tw-tip__head { display: flex; align-items: center; gap: 0.5rem; }
  .tw-tip__dot { width: 0.7rem; height: 0.7rem; border-radius: 999px; background: var(--amber); flex: none; }
  .tw-tip__title { font-family: var(--font-display); font-weight: 600; font-size: 1.05rem; }
  .tw-tip__outcome { margin: 0.4rem 0 0.45rem; font-size: 0.92rem; color: var(--ink-soft); line-height: 1.45; }
  .tw-tip__meta { margin: 0; font-size: 0.8rem; color: var(--ink-faint); text-transform: capitalize; }

  /* legend */
  .tw__legend {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 1.2rem;
    padding: 0.85rem 1.1rem; border-top: 1px solid var(--line);
    background: var(--surface); font-size: 0.85rem; color: var(--ink-soft);
  }
  .tw__leg { display: inline-flex; align-items: center; }
  .tw__sealmark {
    display: inline-flex; align-items: center; justify-content: center;
    width: 1.05rem; height: 1.05rem; border-radius: 999px; margin-right: 0.45em;
    background: #fff; color: var(--evergreen); border: 1.6px solid var(--evergreen);
    font-size: 0.66rem; font-weight: 700;
  }
  .tw__hint { margin-left: auto; color: var(--ink-faint); font-style: italic; }
  @media (max-width: 560px) { .tw__hint { margin-left: 0; } }

  @media (prefers-reduced-motion: reduce) { .tw-crown { animation: none; } }
</style>

<script>
  const root = document.getElementById('treeworld');
  if (root) {
    const tip = root.querySelector('.tw-tip') as HTMLElement | null;
    const stage = root.querySelector('.tw__stage') as HTMLElement | null;
    const hits = Array.from(root.querySelectorAll<SVGRectElement>('.tw-hit'));

    const show = (el: SVGRectElement) => {
      if (!tip || !stage) return;
      const r = el.getBoundingClientRect();
      const cr = stage.getBoundingClientRect();
      (tip.querySelector('.tw-tip__title') as HTMLElement).textContent = el.dataset.title ?? '';
      (tip.querySelector('.tw-tip__outcome') as HTMLElement).textContent = el.dataset.outcome ?? '';
      (tip.querySelector('.tw-tip__status') as HTMLElement).textContent = el.dataset.status ?? '';
      (tip.querySelector('.tw-tip__caps') as HTMLElement).textContent = el.dataset.caps ?? '';

      const status = el.dataset.status ?? 'proposed';
      const dotColor: Record<string, string> = {
        healthy: '#2f6b3f', mapped: '#7d5f3b', proposed: '#b06a24', unhealthy: '#9f2d22',
      };
      (tip.querySelector('.tw-tip__dot') as HTMLElement).style.background = dotColor[status] ?? '#b06a24';

      // position centered above the node, clamped inside the stage
      let left = r.left - cr.left + r.width / 2;
      const half = Math.min(304, cr.width * 0.74) / 2;
      left = Math.max(half + 8, Math.min(cr.width - half - 8, left));
      tip.style.left = left + 'px';
      tip.style.top = r.top - cr.top + 8 + 'px';
      tip.hidden = false;

      hits.forEach((h) => h.closest('.tw-node')?.classList.remove('is-active'));
      el.closest('.tw-node')?.classList.remove('is-active');
      document.getElementById('node-' + el.dataset.id)?.classList.add('is-active');
    };

    const hide = () => {
      if (tip) tip.hidden = true;
      root.querySelectorAll('.tw-node.is-active').forEach((n) => n.classList.remove('is-active'));
    };

    hits.forEach((el) => {
      el.addEventListener('mouseenter', () => show(el));
      el.addEventListener('mouseleave', hide);
      el.addEventListener('focus', () => show(el));
      el.addEventListener('blur', hide);
      el.addEventListener('click', (e) => { e.stopPropagation(); show(el); });
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); show(el); }
        if (e.key === 'Escape') hide();
      });
    });
    document.addEventListener('click', (e) => {
      if (!(e.target as Element)?.closest('.tw-hit')) hide();
    });
  }
</script>
