---
// ---------------------------------------------------------------------------
// TreeWorld — an interactive, build-time-rendered "story world" map of a
// fictional software system. Recreates the depth and game-feel of storytree's
// real studio view (a Dorfromantik-style hex world of status-coloured story
// trees, garden-flora capabilities, dependency roads, witness signposts,
// fresh-verdict blooms and live-session wisps) in fully ORIGINAL SVG, driven
// only by fictional mock JSON. Nothing here copies private studio source.
// ---------------------------------------------------------------------------
import data from '../data/mockSystem.json';
import { buildWorld } from '../lib/world';
import { renderWorld } from '../lib/worldSvg';

const world = buildWorld(data as any);
const svg = renderWorld(world);

const titleById = new Map(world.territories.map((t) => [t.id, t.title]));
const blob = Object.fromEntries(
  world.territories.map((t) => [
    t.id,
    {
      title: t.title,
      outcome: t.outcome,
      vis: t.vis,
      witness: t.witness,
      capCount: t.capCount,
      contractTotal: t.contractTotal,
      deps: t.deps.map((d) => titleById.get(d) ?? d),
      caps: t.caps.map((c) => ({ title: c.title, status: c.status, contracts: c.contracts })),
      dag: t.capDag,
      sessions: t.sessions,
      ancestors: t.ancestors,
      descendants: t.descendants,
    },
  ]),
);
const blobJson = JSON.stringify(blob).replace(/</g, '\\u003c');
const stats = world.stats;

const filters = [
  { key: 'healthy', label: 'Proven' },
  { key: 'mapped', label: 'Mapped' },
  { key: 'proposed', label: 'Building' },
  { key: 'unhealthy', label: 'Needs attention' },
];
---

<figure class="tw-root" id="tw-root">
  <div class="tw-toolbar">
    <div class="tw-title">
      <span class="tw-live" aria-hidden="true"></span>
      <strong>{world.project}</strong>
      <span class="tw-tagline">— {data.tagline}</span>
    </div>
    <div class="tw-stats" aria-label="system summary">
      <span><b>{stats.stories}</b> stories</span>
      <span><b>{stats.caps}</b> capabilities</span>
      <span><b>{stats.contracts}</b> tests</span>
      <span class="s-healthy"><b>{stats.proven}</b> proven</span>
      <span class="s-unhealthy"><b>{stats.unhealthy}</b> need attention</span>
      <span class="s-live"><b>{stats.sessions}</b> working now</span>
    </div>
  </div>

  <div class="tw-filters" role="group" aria-label="Show or hide stories by status">
    <span class="tw-filters-label">show:</span>
    {filters.map((flt) => (
      <button type="button" class={`tw-chip s-${flt.key}`} data-filter={flt.key} aria-pressed="true">
        <span class="tw-chip-dot" aria-hidden="true"></span>{flt.label}
      </button>
    ))}
  </div>

  <div class="tw-body">
    <div class="tw-stage" role="group" aria-label="Interactive map of the Cohoot system — its stories are focusable below.">
      <Fragment set:html={svg} />
    </div>

    <aside class="tw-inspector" id="tw-inspector" data-state="overview">
      <div class="tw-ov" id="tw-ov">
        <p class="tw-ov-eyebrow">The map</p>
        <p class="tw-ov-lead">
          A whole system at a glance. Each tree is a <strong>story</strong> — one slice of the
          product. Its colour is its health, the garden around it is its capabilities, and the
          roads are what it depends on.
        </p>
        <ul class="tw-key">
          <li><span class="dot s-healthy"></span><span><strong>Proven</strong> — a failing test was made to pass, and a person signed off.</span></li>
          <li><span class="dot s-mapped"></span><span><strong>Mapped</strong> — real and in use, but not proven here yet.</span></li>
          <li><span class="dot s-proposed"></span><span><strong>Proposed / building</strong> — agents and people are on it now.</span></li>
          <li><span class="dot s-unhealthy"></span><span><strong>Needs attention</strong> — a check is failing. This is where focus goes next.</span></li>
        </ul>
        <p class="tw-ov-hint">Hover or tap any tree to inspect a story.</p>
      </div>

      <div class="tw-story" id="tw-story" hidden>
        <div class="tw-story-head">
          <span class="tw-badge" id="tw-d-badge"></span>
          <button type="button" class="tw-close" id="tw-d-close" aria-label="Back to the whole map">show all ✕</button>
        </div>
        <h3 id="tw-d-title"></h3>
        <p class="tw-d-outcome" id="tw-d-outcome"></p>
        <p class="tw-d-deps" id="tw-d-deps"></p>
        <div class="tw-d-sessions" id="tw-d-sessions"></div>
        <p class="tw-d-capn" id="tw-d-capn"></p>
        <div class="tw-d-dag" id="tw-d-dag" aria-hidden="true"></div>
        <ul class="tw-d-caps" id="tw-d-caps"></ul>
      </div>
    </aside>
  </div>

  <figcaption class="tw-legend">
    <span class="tw-leg"><span class="tw-leg-sign" aria-hidden="true"></span>signed off by a person</span>
    <span class="tw-leg"><span class="tw-leg-bloom" aria-hidden="true"></span>just passed its check</span>
    <span class="tw-leg"><span class="tw-leg-wisp" aria-hidden="true"></span>someone working here now</span>
    <span class="tw-leg-hint">Hover or tap a tree · click to pin · this is invented data</span>
  </figcaption>

  <script type="application/json" id="tw-data" set:html={blobJson}></script>
</figure>

<style is:global>
  /* ---- shell ---- */
  .tw-root {
    margin: 1.6rem 0 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    background: var(--surface);
  }
  .tw-toolbar {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 0.5rem 1rem; padding: 0.7rem 1rem;
    background: var(--surface-2); border-bottom: 1px solid var(--line);
  }
  .tw-title { font-size: 0.96rem; display: inline-flex; align-items: baseline; gap: 0.4rem; }
  .tw-title strong { font-family: var(--font-display); font-size: 1.08rem; }
  .tw-tagline { color: var(--ink-faint); font-size: 0.86rem; }
  .tw-live {
    width: 0.55rem; height: 0.55rem; border-radius: 999px; background: #2f9e8f;
    align-self: center; box-shadow: 0 0 0 0 rgba(47,158,143,0.5); animation: tw-ping 2.4s ease-out infinite;
  }
  @keyframes tw-ping { 0% { box-shadow: 0 0 0 0 rgba(47,158,143,0.5); } 70%,100% { box-shadow: 0 0 0 6px rgba(47,158,143,0); } }
  .tw-stats { display: flex; flex-wrap: wrap; gap: 0.3rem 0.9rem; font-size: 0.8rem; color: var(--ink-faint); }
  .tw-stats b { color: var(--ink); font-weight: 650; }
  .tw-stats .s-healthy b { color: var(--evergreen); }
  .tw-stats .s-unhealthy b { color: var(--crimson); }
  .tw-stats .s-live b { color: #176b61; }

  /* ---- filter chips ---- */
  .tw-filters { display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem; padding: 0.6rem 1rem; border-bottom: 1px solid var(--line); }
  .tw-filters-label { font-size: 0.78rem; color: var(--ink-faint); margin-right: 0.1rem; }
  .tw-chip {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font: 500 0.8rem var(--font-body); color: var(--ink-soft);
    padding: 0.28rem 0.7rem; border-radius: 999px; cursor: pointer;
    background: var(--surface); border: 1px solid var(--line-strong);
    transition: background 0.15s, opacity 0.15s, border-color 0.15s;
  }
  .tw-chip-dot { width: 0.6rem; height: 0.6rem; border-radius: 999px; }
  .tw-chip.s-healthy .tw-chip-dot { background: var(--evergreen); }
  .tw-chip.s-mapped .tw-chip-dot { background: var(--brown); }
  .tw-chip.s-proposed .tw-chip-dot { background: var(--amber); }
  .tw-chip.s-unhealthy .tw-chip-dot { background: var(--crimson); }
  .tw-chip[aria-pressed='false'] { opacity: 0.45; background: var(--surface-2); text-decoration: line-through; }

  /* ---- body grid ---- */
  .tw-body { display: grid; }
  @media (min-width: 900px) { .tw-body { grid-template-columns: minmax(0, 1.75fr) minmax(258px, 1fr); } }
  .tw-stage {
    position: relative; min-width: 0; max-height: 80vh; overflow: auto;
    background:
      radial-gradient(900px 520px at 70% 0%, rgba(169,200,127,0.16), transparent 60%),
      linear-gradient(180deg, #fbf3ea, #f3e3d2);
    outline: none;
  }
  .tw-stage:focus-visible { box-shadow: inset 0 0 0 2.5px var(--amber); }
  .tw-svg { width: 100%; height: auto; display: block; }

  /* ---- the world ---- */
  .tw-bg { fill: url(#tw-board); }

  /* smoothed organic shore — each island reads as one sandy landmass */
  .tw-shore { fill: #ecdcb4; stroke: #ddc79a; stroke-width: 1; }

  /* relaxed Townscaper land cells (flat, soft cell seams) */
  .tw-cell { stroke: rgba(95,120,60,0.28); stroke-width: 0.7; stroke-linejoin: round; }
  .tw-cell.v0 { fill: #a9c87f; }
  .tw-cell.v1 { fill: #9fc174; }
  .tw-cell.v2 { fill: #b2cf8b; }
  .tw-cell.wheat { fill: #d6b271; }

  /* ---- WASTELAND (mock — not yet in the real system) ----
     A story that's failing its checks dries out to barren, scorched earth — dusty
     tan with patches of ash and char, NOT a solid black slab — so the eye is drawn
     to the trouble without the island going heavy and flat. */
  .tw-isle.st-unhealthy .tw-shore { fill: #c4b48f; stroke: #a3946f; }
  .tw-ground.st-unhealthy .tw-cell { stroke: rgba(70,55,35,0.30); }
  .tw-ground.st-unhealthy .tw-cell.v0 { fill: #a3946f; }    /* dry tan — dominant */
  .tw-ground.st-unhealthy .tw-cell.v1 { fill: #877a5c; }    /* khaki ash */
  .tw-ground.st-unhealthy .tw-cell.v2 { fill: #6a5f4b; }    /* darker scorched patch */
  .tw-ground.st-unhealthy .tw-cell.wheat { fill: #574d3d; } /* char patch (minority) */
  /* greenery reads wrong on barren ground — dry the conifers, drop their snow,
     and mute the dead-flower heads from red to a dead brown. */
  .tw-terr.st-unhealthy .tw-conifer .body { fill: #7a6c52; }
  .tw-terr.st-unhealthy .tw-conifer .snow { opacity: 0; }
  .tw-terr.st-unhealthy .tw-flora .accent,
  .tw-terr.st-unhealthy .tw-flora .dead-head { fill: #6f5a44; }

  .tw-road .bed { fill: none; stroke: #cdb285; stroke-width: 9; stroke-linecap: round; opacity: 0.4; }
  .tw-road .line { fill: none; stroke: #a98e5f; stroke-width: 2.2; stroke-linecap: round; stroke-dasharray: 1 9; opacity: 0.7; }
  #tw-arrow path { fill: #a98e5f; }

  .tw-terr .sh { fill: rgba(60,42,22,0.13); }
  .tw-terr .trunk { fill: #6e533d; }
  .tw-terr .bare path { fill: none; stroke: #6e533d; stroke-width: 1.4; stroke-linecap: round; }
  .tw-terr .litter { fill: #b07a3c; opacity: 0.75; }
  .tw-terr .lo circle { fill: #6b7280; }
  .tw-terr .hi circle { fill: #9ca3af; }
  .tw-terr.st-healthy .lo circle { fill: #2f6b3f; } .tw-terr.st-healthy .hi circle { fill: #55a06a; }
  .tw-terr.st-mapped .lo circle { fill: #7d5f3b; } .tw-terr.st-mapped .hi circle { fill: #a8854f; }
  .tw-terr.st-proposed .lo circle { fill: #b06a24; } .tw-terr.st-proposed .hi circle { fill: #e09a4b; }
  .tw-terr.st-unhealthy .lo circle { fill: #9f2d22; } .tw-terr.st-unhealthy .hi circle { fill: #c75545; }

  .tw-flora .sh { fill: rgba(60,42,22,0.12); }
  .tw-flora .bed { fill: #c6a36a; opacity: 0.5; }
  .tw-flora .stem { fill: none; stroke: #5d8a46; stroke-width: 1.5; stroke-linecap: round; }
  .tw-flora .core { fill: #f7ecd2; }
  .tw-flora .sap-trunk { fill: #7d5f44; }
  .tw-flora .dark { fill: #6b7280; } .tw-flora .light { fill: #9ca3af; }
  .tw-flora.st-healthy .dark { fill: #2f6b3f; } .tw-flora.st-healthy .light { fill: #55a06a; }
  .tw-flora.st-mapped .dark { fill: #7d5f3b; } .tw-flora.st-mapped .light { fill: #a8854f; }
  .tw-flora.st-proposed .dark { fill: #b06a24; } .tw-flora.st-proposed .light { fill: #e09a4b; }
  /* dead silhouettes (the shared core's 6 flora variants — richer than the old web set) */
  .tw-flora .dead { fill: none; stroke: #8a6a4a; stroke-width: 1.2; stroke-linecap: round; }
  .tw-flora .dead-twig { fill: none; stroke: #8a6a4a; stroke-width: 1.2; stroke-linecap: round; stroke-linejoin: round; }
  .tw-flora .dead-head { fill: #a8704a; } .tw-flora .accent { fill: #9f2d22; }
  .tw-flora .dead-ground { fill: rgba(90,70,45,0.18); }
  .tw-flora .litter { fill: #a07a4a; opacity: 0.7; }
  /* an invisible, focusable-free hit disc the core lays under each plant */
  .tw-flora .flora-hit { fill: transparent; }

  .tw-conifer .body { fill: #4f7a3f; } .tw-conifer.c-1 .body { fill: #5d8a46; } .tw-conifer.c-2 .body { fill: #46703a; }
  .tw-conifer .snow { fill: #cfe3b3; opacity: 0.8; }

  .tw-sign .sh { fill: rgba(60,42,22,0.13); }
  .tw-sign .post { fill: #8a6f4c; }
  .tw-sign .head { fill: #fffdfa; stroke-width: 2.4; }
  .tw-sign.seal-filled .head { stroke: #2f6b3f; }
  .tw-sign.seal-filled .tick { fill: none; stroke: #2f6b3f; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .tw-sign.seal-blank .head { stroke: #b9a489; stroke-dasharray: 3 3; }

  .tw-bloom { transform-box: fill-box; transform-origin: center; animation: tw-pulse 2.6s ease-in-out infinite; }
  .tw-bloom .ring { fill: none; stroke: #6fbf86; stroke-width: 2; opacity: 0.85; }
  .tw-bloom .spark { fill: #a9ebbf; }
  @keyframes tw-pulse { 0%,100% { opacity: 0.45; transform: scale(0.88); } 50% { opacity: 1; transform: scale(1.12); } }

  .tw-wisp .glow { fill: #2f9e8f; opacity: 0.2; animation: tw-glow 3s ease-in-out infinite; animation-delay: var(--d, 0s); }
  .tw-wisp .dot { fill: #2f9e8f; }
  .tw-wisp .wisp-hit { fill: transparent; }
  .tw-wisp.band-stale .glow { fill: #c98a3e; } .tw-wisp.band-stale .dot { fill: #c98a3e; }
  .tw-wisp.band-building .glow { fill: #2f9e8f; } .tw-wisp.band-building .dot { fill: #2f9e8f; }
  /* PHASE-RESOLVED build wisp (ADR-0048 §3 v2): the teal "building" band resolves
     into a steady RED cast while the failing test is authored/confirmed, and a
     GREEN pulse once the build is observed green / signed at the gate — the same
     red=unhealthy / green=healthy vocabulary the rest of the map speaks. The band
     flows from the shared scene's phaseBand (the studio's SceneView paints the same
     three bands), so the public demo can't drift from the studio. */
  .tw-wisp.band-red .glow { fill: var(--crimson); opacity: 0.32; animation: none; }
  .tw-wisp.band-red .dot { fill: var(--crimson); }
  .tw-wisp.band-green .glow { fill: var(--evergreen); animation: tw-glow 1.2s ease-in-out infinite; }
  .tw-wisp.band-green .dot { fill: var(--evergreen); }
  @keyframes tw-glow { 0%,100% { opacity: 0.14; } 50% { opacity: 0.42; } }
  /* the shared scene orbits each wisp around its island; the core sets the start
     phase via --phase, the website's CSS spins it (the studio uses SMIL). */
  .tw-wisp { transform-box: fill-box; transform-origin: center; animation: tw-orbit 6s linear infinite; }
  @keyframes tw-orbit { from { transform: rotate(var(--phase, 0deg)); } to { transform: rotate(calc(var(--phase, 0deg) + 360deg)); } }

  .tw-crown { transform-box: fill-box; transform-origin: 50% 100%; animation: tw-sway var(--sway, 7s) ease-in-out infinite; animation-delay: var(--d, 0s); }
  @keyframes tw-sway { 0%,100% { transform: rotate(-1.1deg); } 50% { transform: rotate(1.1deg); } }

  .tw-plate .bg { fill: rgba(255,253,250,0.97); stroke: rgba(70,50,25,0.14); stroke-width: 1; }
  .tw-plate .ttl { font: 650 12px var(--font-body); fill: var(--ink); }
  .tw-plate .sub { font: 500 9.5px var(--font-body); fill: #5d564c; text-transform: capitalize; }

  .tw-hit { fill: transparent; cursor: pointer; outline: none; }
  .tw-hit:focus-visible { outline: 2.5px solid var(--amber); outline-offset: -3px; }

  /* ---- focus + filter states ---- */
  .tw-terr, .tw-road, .tw-ground, .tw-isle { transition: opacity 0.18s ease; }
  .tw-root.has-focus .tw-terr.is-dim { opacity: 0.28; }
  .tw-root.has-focus .tw-road.is-dim { opacity: 0.1; }
  .tw-road.is-anc .line { stroke: #b07d1f; opacity: 1; stroke-width: 2.7; stroke-dasharray: none; }
  .tw-road.is-desc .line { stroke: #b5544a; opacity: 1; stroke-width: 2.7; stroke-dasharray: none; }
  .tw-root.hide-healthy .tw-terr.st-healthy, .tw-root.hide-healthy .tw-flora.st-healthy,
  .tw-root.hide-healthy .tw-ground.st-healthy, .tw-root.hide-healthy .tw-isle.st-healthy { opacity: 0.1 !important; }
  .tw-root.hide-mapped .tw-terr.st-mapped, .tw-root.hide-mapped .tw-flora.st-mapped,
  .tw-root.hide-mapped .tw-ground.st-mapped, .tw-root.hide-mapped .tw-isle.st-mapped { opacity: 0.1 !important; }
  .tw-root.hide-proposed .tw-terr.st-proposed, .tw-root.hide-proposed .tw-flora.st-proposed,
  .tw-root.hide-proposed .tw-ground.st-proposed, .tw-root.hide-proposed .tw-isle.st-proposed { opacity: 0.1 !important; }
  .tw-root.hide-unhealthy .tw-terr.st-unhealthy, .tw-root.hide-unhealthy .tw-flora.st-unhealthy,
  .tw-root.hide-unhealthy .tw-ground.st-unhealthy, .tw-root.hide-unhealthy .tw-isle.st-unhealthy { opacity: 0.1 !important; }

  /* ---- inspector ---- */
  .tw-inspector { border-top: 1px solid var(--line); padding: 1.1rem 1.15rem 1.25rem; background: var(--surface); }
  @media (min-width: 900px) { .tw-inspector { border-top: 0; border-left: 1px solid var(--line); overflow: auto; max-height: 80vh; } }
  .tw-ov-eyebrow { font: 650 0.7rem var(--font-body); letter-spacing: 0.13em; text-transform: uppercase; color: var(--amber); margin: 0 0 0.5rem; }
  .tw-ov-lead { font-size: 0.92rem; color: var(--ink-soft); margin: 0 0 0.9rem; line-height: 1.5; }
  .tw-key { list-style: none; margin: 0 0 0.9rem; padding: 0; display: grid; gap: 0.5rem; }
  .tw-key li { display: flex; gap: 0.55rem; font-size: 0.84rem; color: var(--ink-soft); line-height: 1.4; }
  .tw-key .dot { width: 0.7rem; height: 0.7rem; border-radius: 999px; flex: none; margin-top: 0.28em; }
  .tw-ov-hint { font-size: 0.82rem; color: var(--ink-faint); font-style: italic; margin: 0; }
  .dot.s-healthy { background: var(--evergreen); } .dot.s-mapped { background: var(--brown); }
  .dot.s-proposed { background: var(--amber); } .dot.s-unhealthy { background: var(--crimson); }

  .tw-story-head { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.4rem; }
  .tw-badge { font: 650 0.7rem var(--font-body); letter-spacing: 0.04em; text-transform: uppercase; color: #fff; padding: 0.18rem 0.55rem; border-radius: 999px; background: var(--ink-soft); }
  .tw-badge.s-healthy { background: var(--evergreen); } .tw-badge.s-mapped { background: var(--brown); }
  .tw-badge.s-proposed { background: var(--amber); } .tw-badge.s-unhealthy { background: var(--crimson); }
  .tw-close { background: none; border: 0; color: var(--ink-faint); font: 500 0.78rem var(--font-body); cursor: pointer; padding: 0.2rem 0.3rem; }
  .tw-close:hover { color: var(--ink); }
  .tw-story h3 { margin: 0 0 0.3rem; font-size: 1.18rem; }
  .tw-d-outcome { font-size: 0.92rem; color: var(--ink-soft); margin: 0 0 0.7rem; line-height: 1.5; }
  .tw-d-deps { font-size: 0.82rem; color: var(--ink-faint); margin: 0 0 0.7rem; }
  .tw-d-deps b { color: var(--ink-soft); font-weight: 600; }
  .tw-d-sessions { margin: 0 0 0.7rem; display: grid; gap: 0.35rem; }
  .tw-sess { display: flex; gap: 0.45rem; align-items: baseline; font-size: 0.8rem; color: var(--ink-soft); }
  .tw-sess-band { width: 0.5rem; height: 0.5rem; border-radius: 999px; flex: none; align-self: center; background: #2f9e8f; }
  .tw-sess-band.stale { background: #c98a3e; }
  .tw-sess code { font-size: 0.76rem; color: var(--ink); }
  .tw-d-capn { font: 650 0.74rem var(--font-body); letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint); margin: 0.2rem 0 0.45rem; }
  .tw-d-caps { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.32rem; }
  .tw-d-caps li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--ink-soft); }
  .tw-d-caps .dot { width: 0.6rem; height: 0.6rem; border-radius: 999px; flex: none; }
  .tw-d-caps .tw-cap-ttl { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .tw-d-caps em { margin-left: auto; flex: none; font-style: normal; font-size: 0.72rem; color: var(--ink-faint); white-space: nowrap; }

  /* capability sub-DAG (drill-down) */
  .tw-d-dag { margin: 0 0 0.85rem; overflow-x: auto; }
  .tw-dag { display: block; }
  .tw-de { fill: none; stroke: #c8b48d; stroke-width: 1.4; }
  .tw-dn-bg { fill: var(--surface); stroke: var(--line-strong); stroke-width: 1; }
  .tw-dn-strip { fill: var(--ink-soft); }
  .tw-dn.st-healthy .tw-dn-strip { fill: var(--evergreen); }
  .tw-dn.st-mapped .tw-dn-strip { fill: var(--brown); }
  .tw-dn.st-proposed .tw-dn-strip { fill: var(--amber); }
  .tw-dn.st-unhealthy .tw-dn-strip { fill: var(--crimson); }
  .tw-dn-status { font: 600 8px var(--font-body); fill: #fff; text-transform: uppercase; letter-spacing: 0.05em; }
  .tw-dn-ttl { font: 600 12px var(--font-body); fill: var(--ink); }
  .tw-dn-meta { font: 500 9px var(--font-body); fill: var(--ink-faint); }

  /* ---- legend caption ---- */
  .tw-legend { display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem 1.1rem; padding: 0.8rem 1rem; border-top: 1px solid var(--line); background: var(--surface-2); font-size: 0.82rem; color: var(--ink-soft); }
  .tw-leg { display: inline-flex; align-items: center; gap: 0.45rem; }
  .tw-leg-sign { width: 0.85rem; height: 0.85rem; border-radius: 999px; background: #fffdfa; border: 2px solid var(--evergreen); position: relative; }
  .tw-leg-bloom { width: 0.85rem; height: 0.85rem; border-radius: 999px; border: 2px solid #6fbf86; }
  .tw-leg-wisp { width: 0.7rem; height: 0.7rem; border-radius: 999px; background: #2f9e8f; box-shadow: 0 0 0 4px rgba(47,158,143,0.2); }
  .tw-leg-hint { margin-left: auto; color: var(--ink-faint); font-style: italic; }
  @media (max-width: 620px) { .tw-leg-hint { margin-left: 0; } }
</style>

<script>
  type Cap = { title: string; status: string; contracts: number };
  type Sess = { id: string; workingOn: string; band: string };
  type DagNode = { id: string; title: string; status: string; contracts: number; x: number; y: number };
  type Dag = { w: number; h: number; nodes: DagNode[]; edges: { d: string }[] };
  type Node = {
    title: string; outcome: string; vis: string; witness: string; capCount: number; contractTotal: number;
    deps: string[]; caps: Cap[]; dag: Dag; sessions: Sess[]; ancestors: string[]; descendants: string[];
  };

  const root = document.getElementById('tw-root');
  const dataEl = document.getElementById('tw-data');
  if (root && dataEl) {
    const blob: Record<string, Node> = JSON.parse(dataEl.textContent || '{}');
    const insp = document.getElementById('tw-inspector')!;
    const ov = document.getElementById('tw-ov')!;
    const story = document.getElementById('tw-story')!;
    const hits = Array.from(root.querySelectorAll<SVGRectElement>('.tw-hit'));
    const terrs = Array.from(root.querySelectorAll<SVGGElement>('.tw-terr'));
    const roads = Array.from(root.querySelectorAll<SVGGElement>('.tw-road'));
    const stage = root.querySelector('.tw-stage');

    const LABEL: Record<string, string> = { healthy: 'Proven', mapped: 'Mapped', proposed: 'Building', unhealthy: 'Needs attention' };
    let pinned: string | null = null;

    const el = (id: string) => document.getElementById(id)!;
    const escapeHtml = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    function applyFocus(id: string | null) {
      if (!id) {
        root!.classList.remove('has-focus');
        terrs.forEach((e) => e.classList.remove('is-focus', 'is-anc', 'is-desc', 'is-dim'));
        roads.forEach((e) => e.classList.remove('is-anc', 'is-desc', 'is-dim'));
        return;
      }
      const d = blob[id];
      const anc = new Set([id, ...d.ancestors]);
      const desc = new Set([id, ...d.descendants]);
      root!.classList.add('has-focus');
      terrs.forEach((e) => {
        const eid = e.getAttribute('data-id')!;
        e.classList.remove('is-focus', 'is-anc', 'is-desc', 'is-dim');
        if (eid === id) e.classList.add('is-focus');
        else if (d.ancestors.includes(eid)) e.classList.add('is-anc');
        else if (d.descendants.includes(eid)) e.classList.add('is-desc');
        else e.classList.add('is-dim');
      });
      roads.forEach((e) => {
        const fr = e.getAttribute('data-from')!;
        const to = e.getAttribute('data-to')!;
        e.classList.remove('is-anc', 'is-desc', 'is-dim');
        if (anc.has(fr) && anc.has(to)) e.classList.add('is-anc');
        else if (desc.has(fr) && desc.has(to)) e.classList.add('is-desc');
        else e.classList.add('is-dim');
      });
    }

    const DAG_CW = 112, DAG_CH = 42; // keep in sync with world.ts DAG_CW/DAG_CH
    function renderDag(dag: Dag) {
      const host = el('tw-d-dag');
      if (!dag || !dag.nodes.length) { host.innerHTML = ''; return; }
      const cards = dag.nodes
        .map((nd) => {
          const ttl = nd.title.length > 16 ? nd.title.slice(0, 15) + '…' : nd.title;
          const sw = nd.status === 'unhealthy' ? 'failing' : nd.status;
          return '<g class="tw-dn st-' + nd.status + '" transform="translate(' + nd.x + ' ' + nd.y + ')">'
            + '<rect class="tw-dn-bg" width="' + DAG_CW + '" height="' + DAG_CH + '" rx="7"/>'
            + '<path class="tw-dn-strip" d="M 0 13 L 0 7 Q 0 0 7 0 L ' + (DAG_CW - 7) + ' 0 Q ' + DAG_CW + ' 0 ' + DAG_CW + ' 7 L ' + DAG_CW + ' 13 Z"/>'
            + '<text class="tw-dn-status" x="7" y="10">' + escapeHtml(sw) + '</text>'
            + '<text class="tw-dn-ttl" x="7" y="27">' + escapeHtml(ttl) + '</text>'
            + '<text class="tw-dn-meta" x="' + (DAG_CW - 7) + '" y="' + (DAG_CH - 8) + '" text-anchor="end">' + nd.contracts + ' tests</text>'
            + '</g>';
        })
        .join('');
      const edges = dag.edges.map((e) => '<path class="tw-de" d="' + e.d + '" marker-end="url(#tw-de-arrow)"/>').join('');
      const cw = host.clientWidth || 250;
      const scale = Math.min(cw / dag.w, 280 / dag.h, 1.2);
      const wpx = Math.round(dag.w * scale), hpx = Math.round(dag.h * scale);
      host.innerHTML =
        '<svg class="tw-dag" width="' + wpx + '" height="' + hpx + '" viewBox="0 0 ' + dag.w + ' ' + dag.h + '">'
        + '<defs><marker id="tw-de-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse"><path d="M 0 1.5 L 8 5 L 0 8.5 z" fill="#c8b48d"/></marker></defs>'
        + edges + cards + '</svg>';
    }

    function fillStory(id: string) {
      const d = blob[id];
      const badge = el('tw-d-badge');
      badge.textContent = LABEL[d.vis] || d.vis;
      badge.className = 'tw-badge s-' + d.vis;
      el('tw-d-title').textContent = d.title;
      el('tw-d-outcome').textContent = d.outcome;
      el('tw-d-deps').innerHTML = d.deps.length
        ? 'Depends on <b>' + d.deps.map(escapeHtml).join('</b>, <b>') + '</b>'
        : 'A foundation — nothing else has to work first.';
      const sess = el('tw-d-sessions');
      sess.innerHTML = d.sessions.length
        ? d.sessions
            .map((s) => '<div class="tw-sess"><span class="tw-sess-band ' + (s.band === 'stale' ? 'stale' : '') + '"></span><span><code>' + escapeHtml(s.id) + '</code> — ' + escapeHtml(s.workingOn) + '</span></div>')
            .join('')
        : '';
      el('tw-d-capn').textContent =
        d.capCount + (d.capCount === 1 ? ' capability' : ' capabilities') + ' · ' + d.contractTotal + ' tests';
      el('tw-d-caps').innerHTML = d.caps
        .map((c) => '<li><span class="dot s-' + c.status + '"></span><span class="tw-cap-ttl">' + escapeHtml(c.title) + '</span><em>' + c.contracts + ' tests · ' + escapeHtml(c.status === 'unhealthy' ? 'failing' : c.status) + '</em></li>')
        .join('');
      ov.hidden = true;
      story.hidden = false;
      insp.setAttribute('data-state', 'story');
      renderDag(d.dag);
    }

    function showOverview() {
      ov.hidden = false;
      story.hidden = true;
      insp.setAttribute('data-state', 'overview');
    }

    function preview(id: string) { fillStory(id); applyFocus(id); }
    function revert() {
      if (pinned) { fillStory(pinned); applyFocus(pinned); }
      else { showOverview(); applyFocus(null); }
    }

    hits.forEach((hit) => {
      const id = hit.getAttribute('data-id')!;
      hit.addEventListener('mouseenter', () => preview(id));
      hit.addEventListener('mouseleave', revert);
      hit.addEventListener('focus', () => preview(id));
      hit.addEventListener('blur', revert);
      hit.addEventListener('click', (e) => {
        e.stopPropagation();
        pinned = pinned === id ? null : id;
        revert();
      });
      hit.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); pinned = pinned === id ? null : id; revert(); }
        if (e.key === 'Escape') { pinned = null; (hit as unknown as HTMLElement).blur(); revert(); }
      });
    });

    stage?.addEventListener('click', (e) => {
      if (!(e.target as Element)?.closest('.tw-hit')) { pinned = null; revert(); }
    });
    el('tw-d-close').addEventListener('click', () => { pinned = null; revert(); });

    root.querySelectorAll<HTMLButtonElement>('.tw-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const k = chip.getAttribute('data-filter')!;
        const on = chip.getAttribute('aria-pressed') !== 'false';
        chip.setAttribute('aria-pressed', String(!on));
        root.classList.toggle('hide-' + k, on);
      });
    });
  }
</script>
