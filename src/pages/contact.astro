---
import Base from '../layouts/Base.astro';
// Static prose around the contact form is editable in Keystatic (/keystatic) and
// stored in src/data/contact.json. Rendered with set:html so inline emphasis
// (<em>/<strong>) and entities (&nbsp;) in the copy render as authored. The
// <form> itself (fields, labels, placeholders, here.now wiring) is intentionally
// NOT lifted — form mechanics stay in the template.
import data from '../data/contact.json';
---

<Base
  active="contact"
  title="The front door — storytree"
  description="storytree is invite-only for now, but the door to ask is wide open. If what we're trying to do resonates, reach out."
>
  <section class="section">
    <div class="wrap contact">
      <div class="contact__intro prose">
        <p class="eyebrow" set:html={data.eyebrow}></p>
        <h1 set:html={data.heading}></h1>
        <p class="lede" set:html={data.lede}></p>
        <p class="muted" set:html={data.intro}></p>
      </div>

      <div class="contact__card card">
        <form id="contact-form" novalidate>
          <div class="field">
            <label for="cf-name">Your name <span class="opt">(optional)</span></label>
            <input id="cf-name" name="name" type="text" autocomplete="name" maxlength="120" placeholder="What should we call you?" />
          </div>
          <div class="field">
            <label for="cf-email">Email</label>
            <input id="cf-email" name="email" type="email" required autocomplete="email" placeholder="so we can reply" />
          </div>
          <div class="field">
            <label for="cf-message">What's on your mind?</label>
            <textarea id="cf-message" name="message" required rows="5" maxlength="2000" placeholder="An idea, a hard question, a hole you've spotted, or just hello."></textarea>
          </div>
          <button type="submit" class="btn btn--primary cf-submit" set:html={data.submitLabel}></button>
          <p class="cf-note muted" set:html={data.note}></p>
          <div class="cf-status" id="cf-status" role="status" aria-live="polite" hidden></div>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact { display: grid; gap: clamp(1.6rem, 4vw, 3rem); align-items: start; }
  @media (min-width: 880px) { .contact { grid-template-columns: 1fr 1fr; } }
  .contact__intro h1 { margin-top: 0.2rem; }
  /* :global so emphasis authored in the editable prose (rendered via set:html,
     which Astro does not scope) still picks up the contact em styling. */
  .contact :global(em) { font-style: italic; color: var(--ink); }

  .contact__card { padding: clamp(1.3rem, 3vw, 1.9rem); }
  .field { margin-bottom: 1rem; }
  label { display: block; font-weight: 600; font-size: 0.92rem; margin-bottom: 0.35rem; }
  .opt { font-weight: 400; color: var(--ink-faint); }
  input, textarea {
    width: 100%; font: inherit; font-size: 0.98rem; color: var(--ink);
    background: var(--bg); border: 1px solid var(--line-strong); border-radius: 10px;
    padding: 0.68rem 0.8rem; resize: vertical;
  }
  input:focus, textarea:focus { outline: none; border-color: var(--evergreen); box-shadow: 0 0 0 3px var(--evergreen-soft); }
  .cf-submit { margin-top: 0.4rem; }
  .cf-note { font-size: 0.82rem; margin: 0.7rem 0 0; }
  .cf-status { margin-top: 0.9rem; padding: 0.75rem 0.9rem; border-radius: 10px; font-size: 0.92rem; }
  .cf-status[hidden] { display: none; }
  .cf-status.ok { background: var(--evergreen-soft); color: var(--evergreen-deep); border: 1px solid #bcd9bf; }
  .cf-status.err { background: #fdecea; color: var(--crimson); border: 1px solid #f0c9c3; }
  .cf-status a { color: inherit; font-weight: 600; }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('cf-status') as HTMLElement | null;

  function setStatus(kind: 'ok' | 'err', html: string) {
    if (!statusEl) return;
    statusEl.className = 'cf-status ' + kind;
    statusEl.innerHTML = html;
    statusEl.hidden = false;
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('.cf-submit') as HTMLButtonElement;
      const emailEl = form.elements.namedItem('email') as HTMLInputElement;
      const msgEl = form.elements.namedItem('message') as HTMLTextAreaElement;
      const data = {
        name: (form.elements.namedItem('name') as HTMLInputElement)?.value?.trim() || undefined,
        email: emailEl?.value?.trim(),
        message: msgEl?.value?.trim(),
        source: 'website-front-door',
      };
      emailEl.setAttribute('aria-invalid', String(!data.email));
      msgEl.setAttribute('aria-invalid', String(!data.message));
      if (!data.email || !data.message) {
        setStatus('err', 'Just a line or two and an email to reply to, and we’re set.');
        (!data.email ? emailEl : msgEl)?.focus();
        return;
      }
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = 'Sending…';
      try {
        const res = await fetch('/.herenow/data/submissions', {
          method: 'POST',
          headers: { 'content-type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error('status ' + res.status);
        form.reset();
        setStatus('ok', 'Got it — thank you. We read everything, and we’ll be in touch if it’s a fit.');
      } catch (err) {
        setStatus(
          'err',
          'That didn’t go through just now — the front door is still being wired up. Please try again a little later.'
        );
      } finally {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  }
</script>
