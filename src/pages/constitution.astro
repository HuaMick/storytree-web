---
import Base from '../layouts/Base.astro';
// Rendered verbatim from the founder's draft (src/content/constitution.md).
// Do not rewrite — this is storytree's voice.
import { Content } from '../content/constitution.md';
// The page's footer note lives in src/data/constitution-page.json (plain file edits).
// The constitution BODY stays verbatim from constitution.md (owner standing rule).
import page from '../data/constitution-page.json';
---

<Base
  active="constitution"
  title="The storytree Constitution"
  description="What storytree is trying to show, what it commits to, and how it plans to keep itself honest. A living draft — you'll be able to watch it change."
>
  <section class="section">
    <div class="wrap">
      <article class="doc">
        <Content />
      </article>
      <aside class="doc__foot wrap-prose">
        <hr class="rule" />
        <p class="muted" set:html={page.footerNote}></p>
      </aside>
    </div>
  </section>
</Base>

<style is:global>
  /* Document styling for the rendered constitution markdown. */
  .doc {
    max-width: var(--maxw-prose);
    margin-inline: auto;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: clamp(1.6rem, 4vw, 3.2rem);
  }
  .doc > h1:first-child { margin-top: 0; font-size: clamp(2rem, 4.4vw, 2.9rem); }
  .doc > p:first-of-type + p em,
  .doc > h1 + p em { color: var(--ink-soft); }
  .doc em { font-style: italic; }
  .doc h2 {
    margin-top: 2.1rem;
    padding-top: 0.2rem;
    font-size: clamp(1.35rem, 2.6vw, 1.7rem);
  }
  .doc h2::before {
    content: "";
    display: block;
    width: 2.2rem; height: 3px; border-radius: 3px;
    background: var(--amber);
    margin-bottom: 0.7rem;
  }
  .doc ol { padding-left: 1.2rem; }
  .doc li { margin-bottom: 0.7rem; }
  .doc li::marker { color: var(--amber); font-weight: 650; }
  .doc strong { color: var(--ink); }
</style>

<style>
  .doc__foot { max-width: var(--maxw-prose); margin: 1.8rem auto 0; }
  .doc__foot p { margin: 1.1rem 0 0; font-size: 0.95rem; }
</style>
