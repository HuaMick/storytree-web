---
import Base from '../layouts/Base.astro';
import TreeWorld from '../components/TreeWorld.astro';
// Home hero copy is editable in Keystatic (/keystatic) and stored in
// src/data/home.json. Rendered with set:html so inline emphasis (<em>) and
// entities (&nbsp;) in the copy render as authored.
import home from '../data/home.json';
---

<Base active="home">
  <!-- ───────────────────────── hero: a quick intro ───────────────────────── -->
  <section class="hero section">
    <div class="wrap hero__copy">
      <p class="eyebrow" set:html={home.eyebrow}></p>
      <h1 set:html={home.headline}></h1>
      <p class="hero__disclaimer" set:html={home.disclaimer}></p>
      <p class="lede" set:html={home.lede}></p>
    </div>
  </section>

  <!-- ───────────────────────── the live map, front and centre ───────────────────────── -->
  <section class="section--tight">
    <div class="wrap">
      <TreeWorld />

      <div class="dive prose">
        <p class="taster-eyebrow">A map for you and your AI&nbsp;agents</p>
        <p>
          What you're looking at is a software project being built by AI&nbsp;agents — drawn as a
          living map instead of millions of lines of unverified code. Each tree is one
          <strong>story</strong>: a single slice of the product, a piece of behaviour the agents are
          building.
        </p>
        <p>
          Every line the agents write turns into something you can see here. A bigger island is a more
          complex part of the system, with more built and tested behind it; a <strong>green</strong>
          tree means that part is tested and healthy, while <strong>red</strong> means a check is
          failing — where your attention goes next. It's a bird's-eye view of the whole system, and
          you can drop into any tree to unpack it with your agents. They read the map too — it's how
          they find their way around the system instead of getting lost in the code.
        </p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="/how-it-works/">See how it works →</a>
          <a class="btn btn--ghost" href="/get-involved/">Why this exists · get involved</a>
        </div>
        <p class="hero__note muted">
          Small on purpose. Invite-only for now — but the door to ask is wide open.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero { padding-top: clamp(2.4rem, 6vw, 4.4rem); padding-bottom: clamp(0.8rem, 2.5vw, 1.4rem); }
  .hero__copy { max-width: 50rem; }
  .hero__copy h1 { margin-top: 0.2rem; margin-bottom: 0.55rem; }
  .hero__disclaimer {
    max-width: 42rem; margin: 0 0 1.2rem; font-size: 0.85rem; line-height: 1.55;
    color: var(--ink-faint); border-left: 3px solid var(--line-strong); padding-left: 0.9rem;
  }
  /* :global so emphasis authored in the editable hero copy (rendered via set:html,
     which Astro does not scope) still picks up the hero's em styling. */
  .hero :global(em) { font-style: italic; color: var(--ink); }

  .dive { margin-top: 1.9rem; max-width: 44rem; }
  .dive em { font-style: italic; }
  .dive strong { color: var(--ink); font-weight: 650; }
  .taster-eyebrow {
    font: 650 0.72rem var(--font-body); letter-spacing: 0.13em; text-transform: uppercase;
    color: var(--amber); margin: 0 0 0.55rem;
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.2rem; }
  .hero__note { margin-top: 1.1rem; font-size: 0.95rem; }
</style>
