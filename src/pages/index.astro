---
import Base from '../layouts/Base.astro';
// The accessibility-fallback copy (eyebrow / headline / lede) is editable in
// Keystatic (/keystatic) and stored in src/data/home.json. Rendered with set:html
// so inline emphasis (<em>/<strong>) and entities (&nbsp;) render as authored.
// (The live map + marketing intro were retired from the front door by ADR-0148 §5;
// the map still lives on /how-it-works and its own pages via TreeWorld.astro.)
import home from '../data/home.json';
// The Act 2 guided walk (ADR-0145) renders the SAME buildScene → sceneToSvg map
// SVG the real TreeWorld uses, but this page does NOT mount <TreeWorld/> (the map
// retired from the front door, ADR-0148 §5) — so the map's `tw-*` paint rules are
// not otherwise on the page and the territory/flora would fall back to black fill.
// Pull in the SHARED map-layer stylesheet (one home, referenced by both surfaces).
import '../styles/tree-world-map.css';
// ---------------------------------------------------------------------------
// THE HOME FLIP (ADR-0134 Act 1): the page ships two top-level branches.
//   1. The storm  — [data-experience-entry] — a diegetic AI-agent terminal
//      storm, hidden by default and armed before paint by the inline script
//      below ONLY when JS is available and the visitor has no reduced-motion
//      preference. Plain DOM/CSS + one 2D grain canvas + Web Audio synthesis;
//      no WebGL anywhere in this page's static import closure.
//   2. The calm view — [data-experience-fallback] — today's home content,
//      exactly: no-JS visitors, reduced-motion visitors, and anyone who skips
//      or steps out of the storm land here. The storm is a choice, not a toll
//      booth.
// The skip control [data-experience-skip] is persistent from boot; all three
// markers are machine-held by the parent repo's `check:web-experience`.
// ---------------------------------------------------------------------------
import { BOOT_BANNER, PROMPT_CHIPS, DEFAULT_PROMPT } from '../scripts/storm-script';
---

<Base active="home">
  <!-- Arm the storm BEFORE first paint (is:inline — Astro must not defer this):
       calm by default; enhance to storm only for motion-OK, JS-on visitors.
       The disarm path (skip / Escape / the land's classic affordance) lives here too, so the
       exit works even if the storm engine module never loads. -->
  <script is:inline>
    (function () {
      var de = document.documentElement;
      try {
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          de.classList.add('storm-armed');
        }
      } catch (e) {
        /* no matchMedia → stay calm */
      }
      function disarm() {
        if (!de.classList.contains('storm-armed')) return;
        de.classList.remove('storm-armed');
        try {
          if (window.__stormHalt) window.__stormHalt();
        } catch (e) {
          /* the engine may never have loaded — the calm view stands anyway */
        }
        window.scrollTo(0, 0);
        var calm = document.getElementById('calm-view');
        if (calm) {
          try {
            calm.focus({ preventScroll: true });
          } catch (e) {
            calm.focus();
          }
        }
      }
      document.addEventListener('click', function (ev) {
        var t = ev.target && ev.target.closest ? ev.target.closest('[data-storm-disarm]') : null;
        if (!t) return;
        ev.preventDefault();
        // ADR-0148 §5: the top-left "show me a better way" skip jumps a capable
        // (JS) visitor STRAIGHT into the 2.5D tutorial — the tutorial is the front
        // door, not the static page. If the engine has not loaded (or cannot),
        // fall through to the calm fallback so the exit is never dead.
        if (t.hasAttribute('data-experience-skip') && window.__stormSkipToTutorial) {
          try {
            window.__stormSkipToTutorial();
            return;
          } catch (e) {
            /* engine present but threw — degrade to the calm view below */
          }
        }
        disarm();
      });
      document.addEventListener('keydown', function (ev) {
        if (ev.key === 'Escape') disarm();
      });
    })();
  </script>

  <!-- ─────────────────────────── the storm ─────────────────────────── -->
  <section
    class="storm-root"
    data-experience-entry
    aria-label="A staged demo: one prompt spawns a storm of AI coding agents. Skip any time."
  >
    <div class="storm-hud">
      <a class="storm-skip" href="#calm-view" data-experience-skip data-storm-disarm
        >show me a better way →</a
      >
      <span class="storm-count" id="storm-count" aria-hidden="true">AGENTS: 01</span>
      <button class="storm-sound" id="storm-sound" type="button" aria-pressed="true">
        SOUND ON
      </button>
    </div>

    <div class="storm-stage" id="storm-stage">
      <!-- the boot terminal: already "logged in", prompt ready, silent -->
      <div class="storm-term storm-boot ph-green" id="storm-boot">
        <div class="term-bar" aria-hidden="true">
          <span class="term-dots">● ● ●</span>
          <span class="term-name">swarm — ~/app</span>
          <span class="term-status" id="storm-boot-status">idle</span>
        </div>
        <div class="term-body" id="storm-boot-body" aria-hidden="true">
          {BOOT_BANNER.map((l) => <div class="term-line k-banner">{l}</div>)}
        </div>
        <div class="term-chips" id="storm-chips" role="group" aria-label="Suggested tasks">
          {PROMPT_CHIPS.map((c) => (
            <button type="button" class="term-chip" data-chip>
              {c}
            </button>
          ))}
        </div>
        <form class="term-prompt" id="storm-form">
          <label class="storm-sr" for="storm-input">Give the coding agent a task</label>
          <span class="term-ps1" aria-hidden="true">~/app $</span>
          <input
            id="storm-input"
            name="prompt"
            type="text"
            autocomplete="off"
            spellcheck="false"
            maxlength="120"
            value={DEFAULT_PROMPT}
            placeholder="or type your own task…"
          />
          <button type="submit" class="term-send">run</button>
        </form>
      </div>

      <!-- the spawned sub-agent terminals materialize here (streaming noise —
           hidden from assistive tech; the exits above stay in the tree) -->
      <div class="storm-spawn" id="storm-spawn" aria-hidden="true"></div>
    </div>

    <!-- ONE full-viewport grain pass: animated noise on the canvas, scanlines +
         vignette as its CSS background — never per-terminal filters -->
    <canvas class="storm-grain" id="storm-grain" aria-hidden="true"></canvas>

    <div class="storm-dimmer" aria-hidden="true"></div>

    <!-- at peak: the root agent's finale terminal drops in above the dimmed
         storm and concedes the obvious. Its dialogue streams from the seeded
         plan (storm-script.ts); its primary button is THE TRANSFORM trigger
         (ADR-0134 §2): the engine binds [data-storm-transform] — one click and
         the storm becomes soil, the calm land fades up in place. The ghost
         link is the joke exit: if a wall of terminals is genuinely your thing,
         that product exists. This window holds the page's real controls, so it
         stays in the accessibility tree (only the streamed noise is hidden). -->
    <div
      class="storm-term storm-finale ph-green"
      id="storm-finale"
      role="group"
      aria-label="The lead agent concedes the storm is not working and offers to show a better way"
      hidden
    >
      <div class="term-bar" aria-hidden="true">
        <span class="term-dots">● ● ●</span>
        <span class="term-name">swarm — root</span>
        <span class="term-status" id="storm-finale-status">reporting</span>
      </div>
      <div class="term-body" id="storm-finale-body" aria-hidden="true"></div>
      <div class="finale-actions" id="storm-finale-actions" hidden>
        <button type="button" class="finale-btn finale-btn--primary" data-storm-transform>
          show me the better way →
        </button>
        <a class="finale-btn finale-btn--ghost" href="https://claude.com/product/claude-code">
          i'm fine with this
        </a>
      </div>
    </div>

    <!-- the soil: the terminals' fragments accumulate here as they fall — the
         noise literally becomes the ground of the calm world. -->
    <div class="storm-soil" id="storm-soil" aria-hidden="true"></div>

    <!-- the calm land (ADR-0148 §5): the transform lands the visitor STRAIGHT
         in the 2.5D guided tutorial — no R3F 3D island, no "begin the guided
         walk" second click, no classic-front-page detour. The tutorial module
         is only ever reached via dynamic import() at the transform click and is
         pure SVG/DOM (zero WebGL). Hidden until the transform begins; the walk
         stage + the orchestrator's mock-website proposal mount onto this layer.
         Escape / the storm skip stay the never-stranded exit to the fallback. -->
    <div
      class="storm-land"
      id="storm-land"
      tabindex="-1"
      aria-label="A guided 2.5D walk where one story grows — one step at a time"
      hidden
    >
      <div class="storm-land-canvas" id="storm-land-canvas"></div>
    </div>
  </section>

  <!-- ─────────────────── the accessibility fallback (ADR-0148 §5) ───────────────────
       A CLEAN MINIMAL static page — NOT the old marketing homepage, and NOT an
       escape a capable visitor is offered. It is graceful degradation only: no-JS
       and reduced-motion visitors land here (and the storm's skip / Escape route
       here too), never stranded, with honest links onward. `data-experience-fallback`
       stays physically in this source (the parent's check:web-experience greps for
       it, and for data-experience-skip in the storm HUD above). The headline copy
       stays editable in Keystatic (home.json). -->
  <div class="calm-view" id="calm-view" tabindex="-1" data-experience-fallback>
    <section class="fallback section">
      <div class="wrap fallback__copy">
        <p class="eyebrow" set:html={home.eyebrow} />
        <h1 set:html={home.headline} />
        <p class="lede" set:html={home.lede} />
        <p class="fallback__note">
          storytree grows software as a living map of stories, watched as it happens. This is
          the plain-text door; the full guided experience needs JavaScript and motion.
        </p>
        <nav class="fallback__cta" aria-label="Learn more about storytree">
          <a class="btn btn--primary" href="/how-it-works/">how it works</a>
          <a class="btn btn--ghost" href="/get-involved/">get involved</a>
        </nav>
      </div>
    </section>
  </div>
</Base>

<!-- the storm engine (module: deferred, bundled). If it fails for any reason,
     fall back to the calm view — never a dead storm. -->
<script>
  import { runStorm } from '../scripts/act1-storm';
  if (document.documentElement.classList.contains('storm-armed')) {
    try {
      runStorm();
    } catch (err) {
      console.error('storm engine failed — falling back to the calm view', err);
      document.documentElement.classList.remove('storm-armed');
    }
  }
</script>

<style>
  /* ---- the accessibility fallback (ADR-0148 §5): a clean minimal static page,
         graceful degradation only ---- */
  #calm-view:focus {
    outline: none;
  }
  .fallback {
    padding-top: clamp(2.8rem, 8vw, 5.5rem);
    padding-bottom: clamp(1.4rem, 4vw, 2.6rem);
  }
  .fallback__copy { max-width: 42rem; }
  .fallback__copy h1 { margin-top: 0.2rem; margin-bottom: 0.7rem; }
  /* :global so emphasis authored in the editable copy (rendered via set:html,
     which Astro does not scope) still picks up the italic styling. */
  .fallback :global(em) { font-style: italic; color: var(--ink); }
  .fallback__note {
    margin: 1rem 0 0; max-width: 38rem;
    font-size: 0.92rem; line-height: 1.6; color: var(--ink-soft);
  }
  .fallback__cta { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.5rem; }
</style>

<style is:global>
  /* ======================================================================
     Act 1 — the terminal storm. Global (not Astro-scoped) because the
     sub-agent terminals are created by the engine at runtime. Everything
     is namespaced storm-/term- to stay out of the site's way.
     ====================================================================== */

  /* ---- arming: calm by default, storm only under html.storm-armed ---- */
  .storm-root { display: none; }
  html.storm-armed .storm-root { display: block; }
  html.storm-armed .nav,
  html.storm-armed .foot,
  html.storm-armed .calm-view { display: none; }
  html.storm-armed body { background: #060a08; overflow: hidden; }

  /* ---- the room: dark phosphor, the deliberate inverse of the cream calm ---- */
  .storm-root {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: radial-gradient(120% 90% at 50% 30%, #0b1410 0%, #060a08 55%, #030504 100%);
    color: #9fe8b4;
    --font-term: ui-monospace, 'Cascadia Mono', 'SF Mono', Menlo, Consolas, monospace;
    font-family: var(--font-term);
  }

  .storm-sr {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* ---- HUD: the skip (persistent from boot), the arcade counter, sound ---- */
  .storm-hud {
    position: absolute; top: 0; left: 0; right: 0; z-index: 48;
    display: flex; align-items: center; gap: 14px;
    padding: 10px 14px;
    font: 600 11.5px/1 var(--font-term);
    letter-spacing: 0.1em;
  }
  .storm-skip {
    color: #d8ffe4; text-decoration: none; text-transform: lowercase;
    border: 1px solid rgba(126, 255, 165, 0.4);
    background: rgba(6, 14, 9, 0.72);
    padding: 8px 13px; border-radius: 4px;
  }
  .storm-skip:hover { background: rgba(126, 255, 165, 0.14); color: #ffffff; }
  .storm-count {
    margin-left: auto; display: inline-block;
    color: #baffcf; font-size: 13px;
    text-shadow: 0 0 9px rgba(90, 255, 140, 0.55);
  }
  .storm-count.tick { animation: storm-count-pulse 0.5s ease-out; }
  @keyframes storm-count-pulse {
    0% { transform: scale(1.3); filter: brightness(2.2); }
    45% { transform: scale(0.97); }
    100% { transform: scale(1); filter: brightness(1); }
  }
  .storm-sound {
    font: 600 10.5px/1 var(--font-term); letter-spacing: 0.1em;
    color: #9fe8b4; background: rgba(6, 14, 9, 0.72);
    border: 1px solid rgba(126, 255, 165, 0.28);
    padding: 8px 11px; border-radius: 4px; cursor: pointer;
  }
  .storm-sound[aria-pressed='false'] { color: #57806a; text-decoration: line-through; }
  .storm-sound:hover { background: rgba(126, 255, 165, 0.12); }

  /* ---- stage + terminals ---- */
  .storm-stage { position: absolute; inset: 0; z-index: 10; overflow: hidden; }
  .storm-spawn { position: absolute; inset: 0; }

  .storm-term {
    position: absolute;
    display: flex; flex-direction: column; overflow: hidden;
    background: rgba(7, 16, 11, 0.93);
    border: 1px solid rgba(126, 255, 165, 0.26);
    border-radius: 6px;
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.6),
      0 14px 34px rgba(0, 0, 0, 0.55),
      0 0 22px rgba(80, 255, 140, 0.07);
    --ph: #8affa8; --ph-soft: #b8ffcb; --ph-dim: #4e8d63;
  }
  .storm-term.ph-amber {
    --ph: #ffc46b; --ph-soft: #ffe0a8; --ph-dim: #a67c3e;
    border-color: rgba(255, 196, 107, 0.28);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.6),
      0 14px 34px rgba(0, 0, 0, 0.55),
      0 0 22px rgba(255, 180, 80, 0.07);
  }
  /* CRT power-on (individual scale so it composes with the mobile translate) */
  .storm-term.is-new { animation: storm-term-on 0.34s cubic-bezier(0.22, 1.5, 0.36, 1) both; }
  @keyframes storm-term-on {
    0% { scale: 1 0.05; filter: brightness(3); opacity: 0; }
    40% { scale: 1.03 0.55; filter: brightness(1.9); opacity: 1; }
    100% { scale: 1 1; filter: brightness(1); }
  }

  .term-bar {
    flex: none;
    display: flex; align-items: center; gap: 8px;
    padding: 5px 9px;
    background: rgba(10, 24, 16, 0.9);
    border-bottom: 1px solid rgba(126, 255, 165, 0.14);
    font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--ph-dim);
  }
  .term-dots { font-size: 7px; letter-spacing: 2px; color: rgba(126, 255, 165, 0.4); }
  .term-name { color: var(--ph-soft); font-weight: 600; }
  .term-status { margin-left: auto; }
  .storm-term.is-parked .term-status { color: var(--ph); animation: storm-status-blink 1.4s steps(1) infinite; }
  @keyframes storm-status-blink { 50% { opacity: 0.25; } }

  .term-body {
    flex: 1 1 auto; min-height: 0;
    display: flex; flex-direction: column; justify-content: flex-end;
    overflow: hidden;
    padding: 8px 10px 9px;
    font-size: 12px; line-height: 1.5;
    text-shadow: 0 0 7px rgba(120, 255, 160, 0.28);
  }
  .term-line { white-space: pre-wrap; overflow-wrap: break-word; color: var(--ph); }
  .term-line.k-banner { color: var(--ph-dim); }
  .term-line.k-sys { color: var(--ph-dim); font-style: italic; }
  .term-line.k-cmd { color: #eafff0; font-weight: 600; }
  .term-line.k-warn { color: #ff9d76; }
  .term-line.k-ok { color: var(--ph-soft); }
  .term-line.k-spawn { color: #eafff0; font-weight: 700; }
  .term-line.k-demand {
    align-self: flex-start;
    background: var(--ph); color: #071009;
    font-weight: 700;
    padding: 1px 7px; margin-top: 5px; border-radius: 2px;
    text-shadow: none;
  }
  .term-cursor { animation: storm-cur-blink 1.05s steps(1) infinite; }
  @keyframes storm-cur-blink { 50% { opacity: 0; } }

  /* ---- the boot terminal ---- */
  .storm-boot {
    left: 50%; top: 42%; translate: -50% -50%;
    width: min(620px, 92vw);
    z-index: 15;
  }
  .storm-boot .term-body { max-height: 42vh; font-size: 13px; }
  .term-chips { flex: none; display: flex; flex-wrap: wrap; gap: 7px; padding: 6px 10px 2px; }
  .term-chip {
    font: 500 11.5px var(--font-term);
    color: var(--ph-soft);
    background: rgba(126, 255, 165, 0.08);
    border: 1px solid rgba(126, 255, 165, 0.32);
    border-radius: 4px;
    padding: 5px 9px;
    cursor: pointer;
  }
  .term-chip:hover { background: rgba(126, 255, 165, 0.16); }
  .term-prompt { flex: none; display: flex; align-items: center; gap: 7px; padding: 7px 10px 11px; }
  .term-ps1 { color: var(--ph-dim); font-size: 13px; }
  .term-prompt input {
    flex: 1; min-width: 0;
    background: transparent; border: 0; outline: none;
    color: #eafff0; font: 500 13px var(--font-term);
    caret-color: var(--ph);
  }
  .term-prompt input::placeholder { color: rgba(126, 255, 165, 0.4); }
  .term-prompt input:focus-visible { outline: none; box-shadow: 0 1px 0 0 var(--ph); }
  .term-send {
    font: 600 10.5px var(--font-term); letter-spacing: 0.1em; text-transform: uppercase;
    color: #071009; background: var(--ph);
    border: 0; border-radius: 3px;
    padding: 5px 10px; cursor: pointer;
  }
  .storm-root.is-sent .term-chips,
  .storm-root.is-sent .term-prompt { display: none; }

  /* ---- grain: animated noise (canvas) + scanlines & vignette (its background) ---- */
  .storm-grain {
    position: absolute; inset: 0; z-index: 40;
    width: 100%; height: 100%;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        0deg,
        rgba(4, 10, 6, 0.28) 0px, rgba(4, 10, 6, 0.28) 1px,
        transparent 1px, transparent 3px
      ),
      radial-gradient(ellipse 115% 90% at 50% 42%, transparent 55%, rgba(0, 0, 0, 0.5) 100%);
    animation: storm-flicker 7s steps(60) infinite;
  }
  @keyframes storm-flicker {
    0%, 91%, 94%, 96%, 100% { opacity: 1; }
    92% { opacity: 0.86; }
    97% { opacity: 0.93; }
  }

  /* ---- peak: dim the scene, the root agent's finale terminal drops in ---- */
  .storm-dimmer {
    position: absolute; inset: 0; z-index: 45;
    background: rgba(2, 4, 3, 0.55);
    opacity: 0; transition: opacity 1.6s ease;
    pointer-events: none;
  }
  .storm-root.is-peak .storm-dimmer { opacity: 1; }
  /* the finale terminal: same CRT species as the storm windows, just bigger,
     centered above the dimmer (dimmer z 45). CRT power-on entrance reuses
     storm-term-on — `scale` composes with the centering translate. */
  .storm-finale {
    left: 50%; top: 50%; translate: -50% -50%;
    z-index: 46;
    width: min(640px, 92vw);
    max-height: min(70vh, 560px);
  }
  .storm-finale[hidden] { display: none; }
  .storm-root.is-peak .storm-finale {
    animation: storm-term-on 0.42s 0.9s cubic-bezier(0.22, 1.5, 0.36, 1) both;
  }
  .storm-finale .term-body {
    min-height: 200px;
    max-height: 46vh;
    font-size: 13px;
  }
  /* the two options: hidden until the stream lands, then a soft fade-up */
  .finale-actions {
    flex: none;
    display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
    padding: 12px 14px 14px;
    border-top: 1px solid rgba(126, 255, 165, 0.14);
  }
  .finale-actions[hidden] { display: none; }
  .storm-finale.is-done .finale-actions { animation: finale-actions-in 0.7s ease both; }
  @keyframes finale-actions-in {
    from { opacity: 0; translate: 0 7px; }
    to { opacity: 1; translate: 0 0; }
  }
  .finale-btn {
    font: 600 12px var(--font-term);
    letter-spacing: 0.05em; text-transform: lowercase;
    border-radius: 4px; padding: 9px 14px;
    cursor: pointer; text-decoration: none;
  }
  .finale-btn--primary { color: #071009; background: var(--ph); border: 0; }
  .finale-btn--primary:hover { filter: brightness(1.15); }
  .finale-btn--ghost {
    color: #6fa585; background: transparent;
    border: 1px solid rgba(126, 255, 165, 0.22);
  }
  .finale-btn--ghost:hover { color: #9fe8b4; background: rgba(126, 255, 165, 0.08); }

  /* ======================================================================
     The inflection (ADR-0134 §2) — one click at peak transforms the storm:
     terminals power off, their fragments fall as soil, the calm land fades
     up in place. State classes (engine-driven): .is-transforming from the
     click, .is-resolved when the island is mounted and the beat has passed.
     ====================================================================== */

  /* the chrome exhales: grain and HUD fade out (animations are cancelled so
     the opacity transition owns the property); the finale terminal joins the
     collapse with the same CRT power-off as the storm windows (later in the
     cascade than the is-peak power-on, so it wins while both classes stand) */
  .storm-root.is-transforming .storm-grain {
    animation: none;
    opacity: 0;
    transition: opacity 1.3s ease;
  }
  /* Once the storm transforms into the tutorial the skip/disarm HUD retires
     entirely — go all in on Act 2 (ADR-0148 §5): fade it out, then flip it
     `visibility: hidden` so it is not just invisible but fully inert (no mouse
     click, out of the tab order) — no capable-visitor escape to the fallback.
     The `data-experience-skip` marker stays in the SOURCE, so check:web-experience
     (which greps the page text) is unaffected; this is runtime-only. */
  .storm-root.is-transforming .storm-hud {
    opacity: 0;
    visibility: hidden;
    transition: opacity 1.5s ease 0.3s, visibility 0s linear 1.8s;
  }
  .storm-root.is-transforming .storm-finale {
    animation: storm-term-off 0.55s 0.3s cubic-bezier(0.55, 0, 0.75, 0.4) both;
    pointer-events: none;
  }

  /* CRT power-off — the inverse of storm-term-on (scale composes with the
     mobile translate the same way) */
  .storm-term.is-off {
    animation: storm-term-off 0.5s cubic-bezier(0.55, 0, 0.75, 0.4) both;
  }
  @keyframes storm-term-off {
    0% { scale: 1 1; filter: brightness(1); opacity: 1; }
    30% { scale: 1.02 0.55; filter: brightness(2.6); opacity: 1; }
    100% { scale: 1 0.04; filter: brightness(3); opacity: 0; }
  }

  /* falling fragments: phosphor text dropping out of the dying windows.
     transform/opacity only — the engine animates each span via WAAPI. */
  .storm-fall {
    position: absolute; inset: 0; z-index: 47;
    overflow: hidden;
    pointer-events: none;
  }
  .storm-frag {
    position: absolute;
    font: 500 12px var(--font-term);
    white-space: nowrap;
    will-change: transform, opacity;
    color: #8affa8;
    text-shadow: 0 0 7px rgba(120, 255, 160, 0.35);
  }
  .storm-frag.ph-amber {
    color: #ffc46b;
    text-shadow: 0 0 7px rgba(255, 180, 80, 0.35);
  }

  /* the soil: a low dark mound the fragments accumulate into. Grows by an
     engine-set scaleY (transform-only — compositor-friendly); rests as the
     loading posture if the island fetch is slow. */
  .storm-soil {
    position: absolute; left: -4vw; right: -4vw; bottom: 0; z-index: 46;
    height: 13vh;
    background: radial-gradient(120% 100% at 50% 100%, #182419 0%, #0d1510 55%, #070c09 100%);
    border-radius: 48% 48% 0 0 / 92% 92% 0 0;
    transform: scaleY(0.045);
    transform-origin: bottom;
    transition: transform 0.5s cubic-bezier(0.25, 0.7, 0.4, 1), opacity 0.9s ease;
    opacity: 0;
    pointer-events: none;
  }
  .storm-root.is-transforming .storm-soil { opacity: 1; }

  /* the skip-straight-to-tutorial jump (ADR-0148 §5): the top-left "show me a
     better way" crosses straight to the tutorial. Unlike the finale transform,
     there is no storm to collapse — so suppress the soil mound and fade any live
     terminals out fast, for a clean cross-dissolve into the land, not a collapse. */
  .storm-root.is-transforming.is-skip .storm-soil { opacity: 0; }
  .storm-root.is-transforming.is-skip .storm-term { opacity: 0; transition: opacity 0.4s ease; }

  /* the calm land: mounted hidden→opacity-0, then fades up as the quiet
     resolves. Sits above all storm chrome (runtime hiding of the skip after
     the transform — its source attribute is untouched). */
  .storm-land {
    position: absolute; inset: 0; z-index: 50;
    opacity: 0;
    pointer-events: none;
    outline: none;
    transition: opacity 2.4s ease;
  }
  .storm-land[hidden] { display: none; }
  .storm-root.is-resolved .storm-land { opacity: 1; pointer-events: auto; }
  .storm-land-canvas { position: absolute; inset: 0; }

  /* ======================================================================
     The session orchestrator CHAT DOCK (ADR-0148 §2 / ADR-0153 §2/§4) — a
     FAITHFUL re-creation of the REAL studio chat dock (apps/studio ChatDock/
     ChatPanel; the site can't import studio React across the repo boundary, so
     the look is replicated against the studio's chat tokens). A warm-dark,
     terminal-style MONOSPACE dock anchored at the BOTTOM of the map frame,
     carrying step 1's OUTCOME BRIEF. Global because act2-orchestrator.ts creates
     the DOM at runtime; namespaced a2chat-. NO skip affordance (ADR-0153 §3).
     ====================================================================== */
  .a2chat-dock {
    /* the studio chat palette (apps/studio/src/index.css, scoped to .chat-dock) */
    --chat-bg: #1e1a15;
    --chat-input-bg: #191510;
    --chat-border-inner: #2c251a;
    --chat-border-outer: #38301f;
    --chat-sage: #8fb87a;
    --chat-reply: #d8cfb8;
    --chat-user: #e7debd;
    --chat-muted: #6f6450;
    --chat-caret: #d9a441;
    --chat-mono: 'SF Mono', 'Cascadia Code', Consolas, 'Liberation Mono', Menlo, ui-monospace, monospace;

    position: absolute; left: 0; right: 0; bottom: 0; z-index: 9;
    display: flex; flex-direction: column;
    max-height: min(64vh, 460px);
    background: var(--chat-bg);
    border-top: 1px solid var(--chat-border-outer);
    border-top-left-radius: 10px; border-top-right-radius: 10px;
    box-shadow: 0 -8px 30px rgba(0, 0, 0, 0.28);
    font-family: var(--chat-mono);
    translate: 0 12px; opacity: 0;
    transition: translate 0.42s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.42s ease;
  }
  .a2chat-dock.is-live { translate: 0 0; opacity: 1; }
  .a2chat-dock.is-leaving { translate: 0 12px; opacity: 0; pointer-events: none; }
  @media (prefers-reduced-motion: reduce) {
    .a2chat-dock, .a2chat-dock.is-leaving { transition: none; translate: 0 0; }
  }

  /* the scrollback (the studio's .chat-outcome): the prompt echo, then the reply */
  .a2chat-scroll {
    flex: 1 1 auto; min-height: 0; overflow-y: auto;
    padding: 16px 18px 10px;
    font-size: 13px; line-height: 1.65;
  }
  .a2chat-glyph { color: var(--chat-sage); font-weight: 700; user-select: none; }
  .a2chat-prompt-echo { display: flex; gap: 0.5ch; margin-bottom: 0.85rem; }
  .a2chat-user { color: var(--chat-user); }
  .a2chat-reply-block { display: flex; gap: 0.5ch; }
  .a2chat-glyph--agent { align-self: flex-start; }
  .a2chat-reply-body { flex: 1; min-width: 0; }
  .a2chat-line {
    margin: 0 0 0.6rem; color: var(--chat-reply);
    transition: opacity 0.4s ease, translate 0.4s ease;
  }
  .a2chat-line.is-hidden { opacity: 0; translate: 0 5px; }
  /* the outcome-brief line — the EXAMPLE, set apart (a quiet card the way the
     studio shows a plan block) */
  .a2chat-brief {
    color: var(--chat-user);
    background: rgba(143, 184, 122, 0.09);
    border-left: 2px solid var(--chat-sage);
    padding: 0.5rem 0.7rem; border-radius: 0 6px 6px 0;
  }
  /* the honest "this is a mock" aside — muted, italic */
  .a2chat-note { color: var(--chat-muted); font-style: italic; }
  @media (prefers-reduced-motion: reduce) {
    .a2chat-line { transition: none; }
    .a2chat-line.is-hidden { opacity: 1; translate: 0 0; }
  }
  /* the streaming caret (amber ▋, 1s step blink — the studio's) */
  .a2chat-caret {
    color: var(--chat-caret);
    animation: a2chat-blink 1s steps(1) infinite;
  }
  .a2chat-caret.is-done { display: none; }
  @keyframes a2chat-blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .a2chat-caret { animation: none; } }

  /* the pinned prompt row (the studio's .chat-form): glyph + the sent prompt
     (inert — a diorama) + the primary that begins the walk */
  .a2chat-form {
    flex: none;
    display: flex; align-items: center; gap: 0.6ch;
    padding: 11px 14px;
    background: var(--chat-input-bg);
    border-top: 1px solid var(--chat-border-inner);
  }
  .a2chat-input {
    flex: 1; min-width: 0;
    color: var(--chat-user); font-size: 13px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    opacity: 0.75;
  }
  .a2chat-actions { flex: none; transition: opacity 0.4s ease; }
  .a2chat-actions.is-hidden { opacity: 0; pointer-events: none; }
  @media (prefers-reduced-motion: reduce) {
    .a2chat-actions { transition: none; }
    .a2chat-actions.is-hidden { opacity: 1; pointer-events: auto; }
  }
  .a2chat-accept {
    border: 1px solid var(--chat-sage); border-radius: 6px; cursor: pointer;
    background: rgba(143, 184, 122, 0.14); color: var(--chat-sage);
    font: 600 12px var(--chat-mono);
    padding: 7px 13px; white-space: nowrap;
  }
  .a2chat-accept:hover { background: rgba(143, 184, 122, 0.24); color: #a9cf92; }
  .a2chat-hint {
    flex: none; margin: 0; padding: 5px 14px 9px;
    background: var(--chat-input-bg);
    font-size: 11px; color: var(--chat-muted);
  }

  /* ======================================================================
     The drive-machinery overlays (ADR-0153 §5/§6) — TEMPORARY flow diagrams
     that float ABOVE the map (not drawn on it) depicting the background
     machinery: the agent loop (top-left, step 2) and the CI/CD / gates / wiring
     (top-right, steps 3-4). Global because act2-overlays.ts creates the DOM at
     runtime; namespaced act2-overlay-. A dark, technical panel (the product's
     background-machinery register), revealed scaffolded and cleared on advance.
     ====================================================================== */
  .act2-overlay {
    position: absolute; z-index: 8;
    width: min(300px, 78vw);
    pointer-events: none; /* the map + callout own interaction; this is a readout */
    opacity: 0;
    transition: opacity 0.42s ease, translate 0.42s cubic-bezier(0.22, 1, 0.36, 1);
    font-family: 'SF Mono', 'Cascadia Code', Consolas, 'Liberation Mono', Menlo, ui-monospace, monospace;
  }
  .act2-overlay--top-left { top: 16px; left: 16px; translate: -8px 0; }
  .act2-overlay--top-right { top: 16px; right: 16px; translate: 8px 0; }
  .act2-overlay.is-live { opacity: 1; translate: 0 0; }
  .act2-overlay.is-leaving { opacity: 0; }
  .act2-overlay--top-left.is-leaving { translate: -8px 0; }
  .act2-overlay--top-right.is-leaving { translate: 8px 0; }
  @media (prefers-reduced-motion: reduce) {
    .act2-overlay { transition: opacity 0.2s ease; translate: 0 0 !important; }
  }
  .act2-overlay-panel {
    background: rgba(24, 20, 15, 0.94);
    border: 1px solid #38301f;
    border-radius: 10px;
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.34);
    padding: 12px 13px 11px;
    color: #d8cfb8;
    backdrop-filter: blur(2px);
  }
  .act2-overlay-head { margin-bottom: 0.55rem; }
  .act2-overlay-eyebrow {
    margin: 0; font: 700 0.6rem 'SF Mono', Consolas, monospace;
    letter-spacing: 0.1em; text-transform: uppercase; color: #8fb87a;
  }
  .act2-overlay-title {
    margin: 0.1rem 0 0; font: 650 0.95rem var(--font-display), serif; color: #efe6cf;
  }
  .act2-overlay-flow { list-style: none; margin: 0; padding: 0; }
  .act2-overlay-row {
    display: flex; gap: 0.6ch; align-items: flex-start;
    padding: 0.32rem 0; position: relative;
    transition: opacity 0.34s ease, translate 0.34s ease;
  }
  /* the connecting spine between steps (a quiet vertical tick) */
  .act2-overlay-row + .act2-overlay-row::before {
    content: ''; position: absolute; left: 7px; top: -0.32rem; height: 0.32rem;
    border-left: 1px dashed #4a4030;
  }
  .act2-overlay-row.is-hidden { opacity: 0; translate: 0 4px; }
  @media (prefers-reduced-motion: reduce) {
    .act2-overlay-row { transition: none; }
    .act2-overlay-row.is-hidden { opacity: 1; translate: 0 0; }
  }
  .act2-overlay-tag {
    flex: none; width: 15px; height: 15px; margin-top: 0.1rem;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 9px; font-weight: 700; border-radius: 4px;
    background: #2c251a; color: #b9ad90;
  }
  .act2-overlay-row.role-run .act2-overlay-tag { background: #24303a; color: #8fbcd6; }
  .act2-overlay-row.role-gate .act2-overlay-tag { background: #3a2420; color: #d6a08f; }
  .act2-overlay-row.role-good .act2-overlay-tag { background: #23331f; color: #8fb87a; }
  .act2-overlay-rowbody { flex: 1; min-width: 0; }
  .act2-overlay-label { margin: 0; font-size: 0.78rem; line-height: 1.35; color: #e7debd; }
  .act2-overlay-note { margin: 0.05rem 0 0; font-size: 0.68rem; line-height: 1.35; color: #8f846a; }
  .act2-overlay-footer {
    margin: 0.6rem 0 0; padding-top: 0.5rem;
    border-top: 1px solid #2c251a;
    font-size: 0.68rem; line-height: 1.4; color: #9a8f74; font-style: italic;
    transition: opacity 0.34s ease;
  }
  .act2-overlay-footer.is-hidden { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    .act2-overlay-footer { transition: none; }
    .act2-overlay-footer.is-hidden { opacity: 1; }
  }

  /* ---- small screens: same cap, stacked windows ---- */
  @media (max-width: 680px) {
    .storm-hud { padding: 8px 10px; gap: 8px; font-size: 10.5px; }
    .storm-count { font-size: 11.5px; }
    .storm-term { left: 50% !important; translate: -50% 0; width: min(420px, 88vw) !important; }
    .storm-boot { top: 40%; translate: -50% -50%; }
    .storm-boot .term-body { font-size: 12px; }
    /* the finale keeps its center + width on small screens (more specific than
       the generic .storm-term stack rule above) */
    .storm-term.storm-finale {
      top: 50%;
      translate: -50% -50%;
      width: min(640px, 92vw) !important;
      max-height: 78vh;
    }
    .storm-finale .term-body { min-height: 150px; font-size: 12px; }
  }

  /* ---- small screens: the chat dock + drive-machinery overlays ---- */
  @media (max-width: 680px) {
    .a2chat-scroll { font-size: 12px; padding: 13px 14px 8px; }
    .a2chat-dock { max-height: min(56vh, 380px); }
    /* the overlays shrink and pin tighter; they still float above the map but
       never cover it — a first-timer can hold one small readout at a time */
    .act2-overlay { width: min(240px, 82vw); }
    .act2-overlay--top-left { top: 10px; left: 10px; }
    .act2-overlay--top-right { top: 10px; right: 10px; }
    .act2-overlay-note { display: none; } /* keep it to the labels on small screens */
    .act2-overlay-panel { padding: 10px 11px 9px; }
  }

  /* ======================================================================
     Act 2 — the guided walk on the REAL 2.5D map (ADR-0145). Global because
     the stage / callout DOM is created at runtime by act2-walkthrough.ts.
     The MAP itself is styled by TreeWorld.astro's tw-* vocabulary (always on
     the page); only the walk chrome (callout, inspect, overlays, chat dock)
     live here, namespaced act2-/a2chat-. (The wrong-way ghost pads + violation
     flag are RETIRED — ADR-0150 §4 / ADR-0153; the dependency layers ARE the teach.)
     ====================================================================== */

  /* ---- the stage: fades up over the R3F canvas at begin ---- */
  .act2-stage {
    position: absolute; inset: 0; z-index: 2;
    opacity: 0;
    transition: opacity 0.9s ease;
    background: radial-gradient(120% 90% at 50% 38%, #fbf3ea 0%, #f3e3d2 55%, #edd9c9 100%);
    font-family: var(--font-body);
  }
  .act2-stage.is-live { opacity: 1; }
  .storm-land.act2-cut .act2-stage { transition: none; }
  .act2-canvas { position: absolute; inset: 0; }
  .act2-stage .tw-svg { width: 100%; height: 100%; display: block; }
  .act2-stage .act2-bg { fill: url(#a2-board); }
  #a2-arrow path { fill: #a98e5f; }
  /* the walk is a diorama, not the studio: the delegation hit layer is inert */
  .act2-stage .tw-hit { pointer-events: none; cursor: default; }
  /* before beat 1 the land is empty — the synthetic territory's tree/plate/hit
     stay out of the render */
  .act2-svg.is-prestory .tw-flora-layer,
  .act2-svg.is-prestory .tw-hits { display: none; }
  /* an inspectable proposed upstream tree (UAT 5) — a soft affordance cue */
  .act2-stage .tw-terr.act2-inspectable { cursor: pointer; }
  .act2-stage .tw-terr.act2-inspectable:hover .tw-plate .bg,
  .act2-stage .tw-terr.act2-inspectable:focus-visible .tw-plate .bg {
    stroke: var(--evergreen); stroke-width: 1.4;
  }
  .act2-stage .tw-terr.act2-inspectable:focus-visible { outline: none; }

  /* ---- growth: what a beat ADDS scales/fades in (deterministic classes;
          scale only ever rides transform-attribute-free groups) ---- */
  .act2-enter {
    transform-box: fill-box; transform-origin: center;
    animation: act2-grow 0.8s cubic-bezier(0.34, 1.4, 0.44, 1) both;
    animation-delay: calc(var(--ei, 0) * 0.22s);
  }
  .act2-enter-fade {
    animation: act2-fade 0.9s ease-out both;
    animation-delay: calc(var(--ei, 0) * 0.3s);
  }
  @keyframes act2-grow { from { opacity: 0; transform: scale(0.55); } to { opacity: 1; transform: scale(1); } }
  @keyframes act2-fade { from { opacity: 0; } to { opacity: 1; } }

  /* ---- the dependency road: a clean "NEEDS" edge from the dependent DOWN to
          its prerequisite (ADR-0153 §1; the wrong-way-flag teach is RETIRED —
          the honest dependency layers ARE the teach, ADR-0150 §4) ---- */
  .act2-stage .tw-road .line {
    stroke: var(--evergreen); stroke-width: 2.2; opacity: 0.85;
    stroke-dasharray: 6 5;
    animation: act2-needs 1.4s linear infinite;
  }
  .act2-stage .tw-road .bed { stroke: #cdbfa6; stroke-width: 4.5; opacity: 0.5; }
  @keyframes act2-needs { to { stroke-dashoffset: -11; } }

  /* ---- the anchored callout (the game-tutorial box, tail at its anchor) ---- */
  .act2-callout {
    position: absolute; z-index: 6;
    width: min(340px, 84vw);
    background: var(--surface); color: var(--ink);
    border-radius: var(--radius);
    box-shadow: 0 16px 48px rgba(40, 26, 12, 0.28);
    padding: 0.95rem 1.1rem 0.9rem;
    opacity: 0; translate: 0 6px; pointer-events: none;
    transition: opacity 0.28s ease, translate 0.28s ease;
  }
  .act2-callout.is-placed { opacity: 1; translate: 0 0; pointer-events: auto; }
  .act2-callout[hidden] { display: none; }
  .act2-tail {
    position: absolute; width: 14px; height: 14px;
    background: var(--surface); rotate: 45deg;
  }
  .act2-head { display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; margin-bottom: 0.35rem; }
  .act2-step {
    margin: 0; font: 650 0.66rem var(--font-body); letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--amber);
  }
  .act2-dots { display: flex; gap: 0.28rem; }
  .act2-dot { width: 0.42rem; height: 0.42rem; border-radius: 999px; background: var(--line-strong); }
  .act2-dot.is-lit { background: var(--amber); }
  .act2-title { margin: 0 0 0.3rem; font-family: var(--font-display); font-size: 1.12rem; color: var(--evergreen); }
  .act2-body { margin: 0; font-size: 0.88rem; line-height: 1.5; color: var(--ink-soft); }
  .act2-legend {
    list-style: none; display: grid; gap: 0.35rem;
    margin: 0.65rem 0 0; padding: 0.65rem 0 0; border-top: 1px solid var(--line);
    font-size: 0.8rem; color: var(--ink-soft);
  }
  /* display:grid would defeat the UA's [hidden] rule — the legend shows ONLY
     on the pull-back beat */
  .act2-legend[hidden] { display: none; }
  .act2-legend li { display: flex; align-items: center; gap: 0.5rem; }
  .act2-legend .k { width: 0.65rem; height: 0.65rem; border-radius: 999px; flex: none; }
  .act2-legend .k-green { background: var(--evergreen); }
  .act2-legend .k-pale { background: var(--amber); }
  .act2-legend .k-with { background: var(--crimson); }
  .act2-controls { display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; margin-top: 0.85rem; }
  .act2-back {
    background: none; border: 0; cursor: pointer;
    font: 500 0.82rem var(--font-body); color: var(--ink-faint); padding: 0.35rem 0.3rem;
  }
  .act2-back:hover { color: var(--ink); }
  /* keep Next pinned right while Back is absent (intro) */
  .act2-back[hidden] { display: block; visibility: hidden; }

  /* ---- the inline inspect prompt (UAT 5 — open a proposed upstream story) ---- */
  .act2-inspect-open {
    display: block; margin: 0.7rem 0 0;
    border: 1px solid var(--evergreen); border-radius: 999px; cursor: pointer;
    background: var(--evergreen-soft); color: var(--evergreen-deep);
    font: 600 0.82rem var(--font-body);
    padding: 0.4rem 0.8rem; text-align: left; width: 100%;
  }
  .act2-inspect-open[hidden] { display: none; }
  .act2-inspect-open:hover { background: #dcebd9; }

  /* ---- the inspect panel: what a proposed upstream story is + why (UAT 5) ---- */
  .act2-inspect {
    position: absolute; inset: 0; z-index: 9;
    display: flex; align-items: center; justify-content: center;
    padding: 1.2rem;
    background: rgba(30, 22, 12, 0.28);
    opacity: 0; pointer-events: none;
    transition: opacity 0.24s ease;
  }
  .act2-inspect.is-open { opacity: 1; pointer-events: auto; }
  .act2-inspect[hidden] { display: none; }
  .act2-inspect-card {
    width: min(430px, 92vw);
    background: var(--surface); color: var(--ink);
    border-radius: var(--radius);
    box-shadow: 0 24px 80px rgba(40, 26, 12, 0.4);
    padding: 1.3rem 1.4rem 1.2rem;
    translate: 0 8px; transition: translate 0.24s ease;
  }
  .act2-inspect.is-open .act2-inspect-card { translate: 0 0; }
  .act2-inspect-badge {
    display: inline-block; margin-bottom: 0.6rem;
    font: 700 0.62rem var(--font-body); letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--amber); background: var(--amber-soft);
    padding: 0.26rem 0.55rem; border-radius: 999px;
  }
  .act2-inspect-title { margin: 0 0 0.5rem; font-family: var(--font-display); font-size: 1.2rem; color: var(--evergreen); }
  .act2-inspect-h {
    margin: 0.7rem 0 0.15rem; font: 700 0.7rem var(--font-body);
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-faint);
  }
  .act2-inspect-p { margin: 0; font-size: 0.9rem; line-height: 1.55; color: var(--ink-soft); }
  .act2-inspect-close {
    margin-top: 1rem; border: 1px solid var(--line-strong); border-radius: 8px; cursor: pointer;
    background: var(--surface-2); color: var(--ink);
    font: 600 0.82rem var(--font-body); padding: 0.45rem 0.95rem;
  }
  .act2-inspect-close:hover { background: var(--surface); }
  @media (prefers-reduced-motion: reduce) {
    .act2-inspect, .act2-inspect-card { transition: none; }
    .act2-inspect.is-open .act2-inspect-card { translate: 0 0; }
  }

  /* ---- the honest diorama-closing CTA ---- */
  .act2-done {
    position: absolute; left: 50%; top: 50%; translate: -50% -50%; z-index: 8;
    width: min(470px, 90vw);
    background: var(--surface); color: var(--ink);
    border-radius: var(--radius);
    box-shadow: 0 24px 80px rgba(40, 26, 12, 0.4);
    padding: 1.5rem 1.7rem 1.3rem;
    text-align: center;
  }
  .act2-done[hidden] { display: none; }
