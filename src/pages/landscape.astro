---
import Base from '../layouts/Base.astro';
import Scorecard from '../components/Scorecard.astro';
import ConvergenceTimeline from '../components/ConvergenceTimeline.astro';
// Landscape prose copy is editable in Keystatic (/keystatic) and stored in
// src/data/landscape.json. Rendered with set:html so inline emphasis
// (<em>/<strong>) and entities (&nbsp;) in the copy render as authored.
import data from '../data/landscape.json';
---

<Base
  active="landscape"
  title="The landscape — where storytree fits, honestly"
  description="A neutral, primary-sourced survey of the AI-coding-agent field against storytree's three surfaces: a library, a code map, and a work-board. Who built what, what might be new, and the honest case that it's mostly renaming."
>
  <!-- intro -->
  <section class="section">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.introEyebrow}></p>
      <h1 set:html={data.introHeading}></h1>
      <p class="lede" set:html={data.introLede}></p>
      <p set:html={data.introBody1}></p>
      <p set:html={data.introBody2}></p>
    </div>
  </section>

  <!-- the scorecard -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.surveyEyebrow}></p>
      <h2 set:html={data.surveyHeading}></h2>
      <p set:html={data.surveyBody}></p>
    </div>
    <div class="wrap">
      <Scorecard />
    </div>
    <div class="wrap prose legend-note">
      <p class="muted" set:html={data.surveyLegendNote}></p>
    </div>
  </section>

  <!-- what might be new -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.newEyebrow}></p>
      <h2 set:html={data.newHeading}></h2>
      <p set:html={data.newBody1}></p>
      <p set:html={data.newBody2}></p>
      <p class="muted" set:html={data.newCaveat}></p>
    </div>
  </section>

  <!-- the field converged -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.convergedEyebrow}></p>
      <h2 set:html={data.convergedHeading}></h2>
      <p set:html={data.convergedBody}></p>
    </div>
    <div class="wrap">
      <ConvergenceTimeline />
    </div>
  </section>

  <!-- the honest box -->
  <section class="section" id="caveats">
    <div class="wrap">
      <div class="honest">
        <div class="honest__inner">
          <p class="eyebrow" set:html={data.honestEyebrow}></p>
          <h2 set:html={data.honestHeading}></h2>
          <p class="lede" set:html={data.honestLede}></p>
          <p set:html={data.honestBody}></p>

          <div class="honest__caveats">
            <h3 set:html={data.caveatsHeading}></h3>
            <ul class="caveats">
              {data.caveats.map((c) => (
                <li set:html={c.text}></li>
              ))}
            </ul>
          </div>

          <p class="honest__src" set:html={data.honestSrc}></p>
        </div>
      </div>
    </div>
  </section>

  <!-- cta -->
  <section class="section--tight">
    <div class="wrap prose cta-card">
      <h2 set:html={data.ctaHeading}></h2>
      <p class="lede" set:html={data.ctaLede}></p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/how-it-works/" set:html={data.ctaPrimary}></a>
        <a class="btn btn--ghost" href="/get-involved/" set:html={data.ctaGhost}></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .legend-note { margin-top: 1rem; }
  .legend-note p { font-size: 0.92rem; margin: 0; }
  /* :global so emphasis authored in the editable copy (rendered via set:html,
     which Astro does not scope) still picks up the italic em styling. */
  :global(em) { font-style: italic; }

  .honest {
    background: var(--surface);
    border: 1px solid var(--line-strong);
    border-left: 5px solid var(--amber);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .honest__inner { padding: clamp(1.6rem, 4vw, 2.8rem); max-width: 48rem; }
  .honest .eyebrow { color: var(--amber); }
  .honest__caveats { margin-top: 1.6rem; padding-top: 1.4rem; border-top: 1px dashed var(--line-strong); }
  .honest__caveats h3 { margin-bottom: 0.8rem; }
  .caveats { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.85rem; }
  .caveats li {
    position: relative; padding-left: 1.5rem; color: var(--ink-soft); font-size: 0.96rem;
  }
  .caveats li::before {
    content: ""; position: absolute; left: 0; top: 0.62em; width: 0.5rem; height: 0.5rem;
    border-radius: 999px; background: var(--amber-soft); box-shadow: inset 0 0 0 2px var(--amber);
  }
  .caveats strong { color: var(--ink); }
  .honest__src {
    margin: 1.6rem 0 0; padding-top: 1.2rem; border-top: 1px solid var(--line);
    font-size: 0.88rem; color: var(--ink-faint);
  }

  .cta-card { text-align: center; max-width: 40rem; }
  .cta-card .hero__cta { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.4rem; justify-content: center; }
</style>
