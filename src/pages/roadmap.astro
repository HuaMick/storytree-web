---
import Base from '../layouts/Base.astro';
import RoadmapDag from '../components/RoadmapDag.astro';
// Page prose is editable in Keystatic (/keystatic) -> src/data/roadmap-page.json.
// The roadmap DATA itself stays in roadmap.json (RoadmapDag) — slated for
// generate-from-source per ADR-0066.
import page from '../data/roadmap-page.json';
---

<Base
  active="roadmap"
  title="The storytree roadmap"
  description="storytree's roadmap as a dependency map, not a timeline: build this first, and it unlocks that. Some work waits behind milestones — real-world conditions like having members and being able to sustain itself."
>
  <!-- intro -->
  <section class="section">
    <div class="wrap prose">
      <p class="eyebrow" set:html={page.introEyebrow}></p>
      <h1 set:html={page.introHeading}></h1>
      <p class="lede" set:html={page.introLede}></p>
      <p set:html={page.introBody}></p>
    </div>
  </section>

  <!-- the map -->
  <section class="section--tight">
    <div class="wrap">
      <RoadmapDag />
    </div>
  </section>

  <!-- honesty note + cta -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={page.promiseEyebrow}></p>
      <h2 set:html={page.promiseHeading}></h2>
      <p set:html={page.promiseBody}></p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/how-it-works/" set:html={page.ctaPrimary}></a>
        <a class="btn btn--ghost" href="/contact/" set:html={page.ctaGhost}></a>
      </div>
    </div>
  </section>
</Base>
