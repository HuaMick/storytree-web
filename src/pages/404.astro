---
import Base from '../layouts/Base.astro';
import page from '../data/not-found.json';
---
<Base title="Not found — storytree" description="That path doesn't exist (yet).">
  <section class="section nf">
    <div class="wrap prose">
      <p class="eyebrow" set:html={page.eyebrow}></p>
      <h1 set:html={page.heading}></h1>
      <p class="lede" set:html={page.lede}></p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/" set:html={page.ctaPrimary}></a>
      </div>
    </div>
  </section>
</Base>
<style>
  .nf { padding-block: clamp(4rem, 12vw, 8rem); }
  .nf .hero__cta { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.4rem; }
</style>
