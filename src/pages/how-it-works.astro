---
import Base from '../layouts/Base.astro';
import TreeWorld from '../components/TreeWorld.astro';
import AgentMaze from '../components/AgentMaze.astro';
// Prose copy for this page lives in src/data/how-it-works.json (plain file
// edits). Rendered with set:html so inline emphasis
// (<em>/<strong>/<code>) and entities (&nbsp;) in the copy render as authored.
import data from '../data/how-it-works.json';
---

<Base
  active="how"
  title="How storytree works"
  description="A live map of your system, a library where intent is decided, and a harness that holds the agents to it — built for people shipping software with AI agents."
>
  <!-- intro -->
  <section class="section">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.introEyebrow}></p>
      <h1 set:html={data.introHeading}></h1>
      <p class="lede" set:html={data.introLede}></p>
    </div>

    <div class="wrap">
      <AgentMaze />
    </div>

    <div class="wrap prose">
      <p set:html={data.introBody1}></p>
      <p set:html={data.introBody2}></p>
    </div>

    <div class="wrap">
      <div class="grid grid--3 trio">
        {data.trio.map((c) => (
          <div class="card trio__card">
            <span class="trio__tag" set:html={c.tag}></span>
            <p set:html={c.body}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- THE MAP + demo -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.mapEyebrow}></p>
      <h2 set:html={data.mapHeading}></h2>
      <p set:html={data.mapBody1}></p>
      <p set:html={data.mapBody2}></p>
    </div>

    <div class="wrap">
      <TreeWorld />
    </div>

    <div class="wrap prose legend-note">
      <p class="muted" set:html={data.legendNote}></p>
    </div>

    <div class="wrap prose">
      <p set:html={data.mapBody3}></p>
    </div>
  </section>

  <!-- the grain -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.grainEyebrow}></p>
      <h2 set:html={data.grainHeading}></h2>
      <p set:html={data.grainBody}></p>
      <div class="grid grid--3 ladder">
        {data.ladder.map((c) => (
          <div class="card">
            <span class="dot dot--healthy"></span><strong set:html={c.title}></strong>
            <p class="muted" set:html={c.body}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DAG as health monitor -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.graphEyebrow}></p>
      <h2 set:html={data.graphHeading}></h2>
      <p set:html={data.graphBody1}></p>
      <p set:html={data.graphBody2}></p>
    </div>
  </section>

  <!-- the harness / gates -->
  <section class="section">
    <div class="wrap band2">
      <div class="band2__inner prose">
        <p class="eyebrow" set:html={data.harnessEyebrow}></p>
        <h2 set:html={data.harnessHeading}></h2>
        <p set:html={data.harnessBody1}></p>
        <p data-grounds="ADR-0020,ADR-0040" set:html={data.harnessBody2}></p>
        <ul class="checks">
          {data.checks.map((c) => (
            <li data-grounds={c.grounds || undefined} set:html={c.body}></li>
          ))}
        </ul>
        <p class="band2__caveat" set:html={data.harnessCaveat}></p>
      </div>
    </div>
  </section>

  <!-- the library / coordination -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.libraryEyebrow}></p>
      <h2 set:html={data.libraryHeading}></h2>
      <p set:html={data.libraryBody1}></p>
      <p set:html={data.libraryBody2}></p>
    </div>
  </section>

  <!-- why this is different -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.differentEyebrow}></p>
      <h2 set:html={data.differentHeading}></h2>
      <p set:html={data.differentBody1}></p>
      <p set:html={data.differentBody2}></p>
      <p set:html={data.differentBody3}></p>
      <p class="muted" set:html={data.differentMuted}></p>
    </div>
  </section>

  <!-- the industry's words for it (ADR-0165 §8: the terms the experience embodies,
       named + cited ONCE, on this page only; the §9 honesty rules bind this copy) -->
  <section class="section--tight">
    <div class="wrap prose" data-grounds="ADR-0165">
      <p class="eyebrow" set:html={data.termsEyebrow}></p>
      <h2 set:html={data.termsHeading}></h2>
      {data.terms.map((t) => (
        <p class="term"><strong set:html={t.term}></strong> — <span set:html={t.body}></span></p>
      ))}
    </div>
  </section>

  <!-- cta -->
  <section class="section">
    <div class="wrap prose cta-card">
      <h2 set:html={data.ctaHeading}></h2>
      <p class="lede" set:html={data.ctaLede}></p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/get-involved/" set:html={data.ctaPrimary}></a>
        <a class="btn btn--ghost" href="/constitution/" set:html={data.ctaGhost}></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .trio { margin-top: 1.6rem; }
  .trio__card { display: flex; flex-direction: column; gap: 0.5rem; }
  .trio__tag {
    align-self: flex-start;
    font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: var(--evergreen-deep);
    border-bottom: 2px solid var(--sage-leaf); padding-bottom: 0.15rem;
  }
  .trio__card p { margin: 0; color: var(--ink-soft); font-size: 0.96rem; }

  .legend-note { margin-top: 1rem; }
  .legend-note p { font-size: 0.92rem; margin: 0; }
  .term strong { font-family: var(--font-display); font-size: 1.05rem; }
  .ladder { margin-top: 1.3rem; }
  .ladder .card p { margin: 0.4rem 0 0; }
  .ladder .card strong { font-family: var(--font-display); font-size: 1.12rem; }
  /* :global on code so the <code> rendered via set:html (which Astro does not
     scope) still picks up the inline-code styling. */
  .ladder :global(code), .band2 :global(code), .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.86em; background: var(--surface-2); padding: 0.05em 0.35em; border-radius: 5px;
  }

  .band2 {
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 5px solid var(--evergreen);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .band2__inner { padding: clamp(1.6rem, 4vw, 2.8rem); max-width: 46rem; }
  .band2__caveat {
    margin-top: 1.3rem; padding-top: 1.1rem; border-top: 1px dashed var(--line-strong);
    font-size: 0.92rem; color: var(--ink-soft);
  }
  .checks { list-style: none; padding: 0; margin: 1.2rem 0 0; display: grid; gap: 0.7rem; }
  .checks li { position: relative; padding-left: 1.9rem; color: var(--ink-soft); }
  .checks li::before {
    content: ""; position: absolute; left: 0; top: 0.35em;
    width: 1.15rem; height: 1.15rem; border-radius: 999px;
    background: var(--evergreen-soft);
    box-shadow: inset 0 0 0 2px var(--evergreen);
  }
  .checks li::after {
    content: ""; position: absolute; left: 0.34rem; top: 0.62em;
    width: 0.42rem; height: 0.24rem; border-left: 2px solid var(--evergreen); border-bottom: 2px solid var(--evergreen);
    transform: rotate(-45deg);
  }
  .cta-card { text-align: center; max-width: 40rem; }
  .cta-card .hero__cta { justify-content: center; }
  /* :global so emphasis rendered via set:html (which Astro does not scope)
     still picks up the page's em styling. */
  :global(em) { font-style: italic; }
</style>
