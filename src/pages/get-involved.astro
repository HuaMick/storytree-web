---
import Base from '../layouts/Base.astro';
// Get-involved prose is editable in Keystatic (/keystatic) and stored in
// src/data/get-involved.json. Rendered with set:html so inline emphasis and
// entities (&nbsp;) in the copy render as authored.
import data from '../data/get-involved.json';
---

<Base
  active="get-involved"
  title="Get involved — storytree"
  description="Why storytree exists, how it tries to keep itself honest, what it commits to, and how to take part. Invite-only for now — but the door to ask is wide open."
>
  <!-- intro -->
  <section class="section">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.intro.eyebrow}></p>
      <h1 set:html={data.intro.h1}></h1>
      <p class="lede" set:html={data.intro.lede}></p>
    </div>
  </section>

  <!-- the bet -->
  <section class="section--tight">
    <div class="wrap band">
      <div class="band__inner">
        <p class="eyebrow" set:html={data.bet.eyebrow}></p>
        <h2 set:html={data.bet.h2}></h2>
        <p class="lede" set:html={data.bet.lede}></p>
      </div>
    </div>
  </section>

  <!-- how we keep ourselves honest -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.honest.eyebrow}></p>
      <h2 set:html={data.honest.h2}></h2>
      <p set:html={data.honest.body}></p>
      <p class="muted" set:html={data.honest.muted}></p>
    </div>
  </section>

  <!-- the constitution -->
  <section class="section--tight">
    <div class="wrap prose">
      <p class="eyebrow" set:html={data.constitution.eyebrow}></p>
      <h2 set:html={data.constitution.h2}></h2>
      <p set:html={data.constitution.body}></p>
      <a class="btn btn--ghost" href="/constitution/" set:html={data.constitution.cta}></a>
    </div>
  </section>

  <!-- where we are + come in -->
  <section class="section">
    <div class="wrap prose front">
      <p class="eyebrow" set:html={data.where.eyebrow}></p>
      <h2 set:html={data.where.h2}></h2>
      <p set:html={data.where.body}></p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/contact/" set:html={data.where.ctaPrimary}></a>
        <a class="btn btn--ghost" href="/how-it-works/" set:html={data.where.ctaGhost}></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.6rem; }
  .front h2 { margin-top: 0.2rem; }

  .band {
    background: linear-gradient(135deg, #2f6b3f 0%, #245031 100%);
    border-radius: calc(var(--radius) + 4px);
    box-shadow: var(--shadow);
    overflow: hidden;
    position: relative;
  }
  .band::after {
    content: ""; position: absolute; inset: 0;
    background:
      radial-gradient(420px 300px at 92% -20%, rgba(169,200,127,0.30), transparent 60%),
      radial-gradient(360px 260px at 0% 120%, rgba(214,178,113,0.22), transparent 60%);
    pointer-events: none;
  }
  .band__inner { position: relative; padding: clamp(2rem, 5vw, 3.4rem); max-width: 46rem; }
  .band .eyebrow { color: #f2cd92; }
  .band h2 { color: #fdf6ec; margin-bottom: 0.7rem; }
  .band .lede { color: #e7ecdf; }
</style>
