# storytree-web — hosted editor environment (Cloud Run).
#
# Needed ONLY for the hosted Keystatic editor (the `build:editor` / `dev:editor`
# target). The public static site (here.now) and `npm run cms` (local-mode editing)
# use NONE of these — leaving them unset keeps Keystatic in local storage.
#
# The three KEYSTATIC_* values are generated by Keystatic's GitHub App setup flow:
# run `npm run dev:editor`, open /keystatic, and follow "create a GitHub App".
# Keystatic writes them into a local .env. In production they live in Secret
# Manager and are injected at runtime — NEVER commit real values.

# Switches the build to the hosted editor target (node server + GitHub storage).
PUBLIC_STORYTREE_WEB_EDITOR=github

# The GitHub App's public slug — safe to expose to the browser bundle (PUBLIC_).
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# --- secrets (Secret Manager in prod; do NOT commit real values) ---
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
